# Template values for public-acme-keycloak scenario.
# Copy and adjust for your environment/secrets handling.

PUBLIC_BASE_URL=https://hotel.example.com

# TLS files consumed by deploy/compose/my-proxy.yml
TLS_CERT_PATH=./deploy/certs/fullchain.pem
TLS_KEY_PATH=./deploy/certs/privkey.pem

# Keycloak host and bootstrap credentials
KEYCLOAK_HOSTNAME=auth.example.com
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

# Keycloak database settings
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me
