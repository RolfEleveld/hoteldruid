@namespace HotelDroid.Client.Components.Rooms
@using HotelDroid.Client.Services
@inject IRoomApiService RoomApiService
@inject ILanguageService LanguageService

<div class="rpanels">
    <div class="rbox">
        <div class="rheader">@LanguageService.GetText("rooms.title", "Top Rooms")</div>
        <div class="rcontent">
            <p>@LanguageService.GetText("rooms.description", "View and manage your hotel rooms")</p>

            @if (RoomsLoading)
            {
                <p>@LanguageService.GetText("common.loading", "Loading...")</p>
            }
            else if (!Rooms.Any())
            {
                <p>@LanguageService.GetText("rooms.emptyList", "No rooms available")</p>
            }
            else
            {
                <table class="t1">
                    <thead>
                        <tr>
                            <th>@LanguageService.GetText("rooms.room", "Room")</th>
                            <th>@LanguageService.GetText("rooms.capacity", "Capacity")</th>
                            <th>@LanguageService.GetText("rooms.floor", "Floor")</th>
                            <th>@LanguageService.GetText("rooms.house", "House")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var room in Rooms.Take(5))
                        {
                            <tr>
                                <td>@room.Name</td>
                                <td>@room.Capacity</td>
                                <td>@room.FloorNumber</td>
                                <td>@room.HouseNumber</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

<SettingsPanel @ref="SettingsPanel" 
    Title="@LanguageService.GetText("settings.title", "Settings & Management")"
    Description="@LanguageService.GetText("settings.description", "Export and import room configurations")">
</SettingsPanel>

@code {
    private List<RoomDto> Rooms = new();
    private bool RoomsLoading = false;
    private SettingsPanel? SettingsPanel;

    protected override async Task OnInitializedAsync()
    {
        await LanguageService.InitializeAsync();
        await LoadRoomsAsync();
    }

    private async Task LoadRoomsAsync()
    {
        try
        {
            RoomsLoading = true;
            Rooms = await RoomApiService.GetRoomsAsync();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error loading rooms: {ex.Message}");
        }
        finally
        {
            RoomsLoading = false;
        }
    }
}
