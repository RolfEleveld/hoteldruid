@namespace HotelDroid.Client.Components.Rooms
@using HotelDroid.Client.Services
@inject ILanguageService LanguageService

<div class="language-switcher" style="padding: 8px; background: #f5f5f5; border-radius: 5px; display: inline-block;">
    <label style="margin-right: 8px;">
        @LanguageService.GetText("language.switcher", "Language"):
    </label>
    <select @onchange="@OnLanguageChanged" style="padding: 4px 8px; border-radius: 3px;">
        @foreach (var lang in LanguageService.AvailableLanguages)
        {
            <option value="@lang.Code" selected="@(LanguageService.CurrentLanguage == lang.Code)">
                @lang.Name
            </option>
        }
    </select>
</div>

@code {
    private async Task OnLanguageChanged(ChangeEventArgs e)
    {
        var languageCode = e.Value?.ToString();
        if (!string.IsNullOrEmpty(languageCode))
        {
            await LanguageService.SetLanguageAsync(languageCode);
        }
    }
}
