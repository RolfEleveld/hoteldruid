@namespace HotelDroid.Client.Components.Rooms
@using HotelDroid.Client.Services
@inject IRoomApiService RoomApiService
@inject ILanguageService LanguageService

<div class="import-settings-panel">
    <div style="border: 1px solid #e0e0e0; padding: 12px; border-radius: 5px; margin-bottom: 15px;">
        <h5 style="margin-top: 0;">@LanguageService.GetText("import.title", "Import Room Configuration")</h5>
        <p style="font-size: 0.9em; color: #666;">
            @LanguageService.GetText("import.description", "Upload a ZIP file containing room data to import")
        </p>

        <div style="margin: 15px 0;">
            @if (SelectedFile == null)
            {
                <div style="border: 2px dashed #ccc; padding: 30px; text-align: center; border-radius: 5px; cursor: pointer;"
                    class="drag-over-zone">
                    <p>@LanguageService.GetText("import.dragDrop", "Drag and drop your ZIP file here")</p>
                    <p style="font-size: 0.9em; color: #999;">
                        @LanguageService.GetText("import.selectFile", "Select a ZIP file to import")
                    </p>
                    <InputFile OnChange="@HandleFileSelected" accept=".zip" />
                </div>
            }
            else
            {
                <div style="padding: 12px; background: #f0f0f0; border-radius: 5px;">
                    <p>@LanguageService.GetText("import.fileSelected", "File selected"): @SelectedFile.Name</p>
                    <button class="sbutton" @onclick="ClearSelectedFile" style="margin-right: 10px;">
                        @LanguageService.GetText("common.cancel", "Cancel")
                    </button>
                </div>
            }
        </div>

        @if (SelectedFile != null && !ValidationCompleted)
        {
            <div style="margin: 15px 0;">
                <button class="sbutton" @onclick="ValidateImportAsync" disabled="@IsValidating">
                    @if (IsValidating)
                    {
                        <span>@LanguageService.GetText("import.validating", "Validating...")</span>
                    }
                    else
                    {
                        <span>@LanguageService.GetText("import.validate", "Validate")</span>
                    }
                </button>
            </div>
        }

        @if (ValidationCompleted)
        {
            <div style="padding: 10px; border-radius: 3px; margin-top: 10px;"
                class="@(ValidationPassed ? "alert-success" : "alert-error")">
                @if (ValidationPassed)
                {
                    <p>@LanguageService.GetText("import.validationPassed", "Validation passed successfully")</p>
                    <p>@LanguageService.GetText("import.importedCount", "Room(s) imported"): @ImportedCount</p>
                    <p>@LanguageService.GetText("import.updatedCount", "Room(s) updated"): @UpdatedCount</p>
                }
                else
                {
                    <p>@LanguageService.GetText("import.validationFailed", "Validation failed")</p>
                    @foreach (var error in ValidationErrors)
                    {
                        <p style="color: #d32f2f;">- @error</p>
                    }
                }
            </div>
        }

        @if (ValidationPassed && !IsImporting)
        {
            <div style="margin: 15px 0;">
                <button class="sbutton" @onclick="ExecuteImportAsync" disabled="@IsImporting">
                    @LanguageService.GetText("import.execute", "Execute Import")
                </button>
            </div>
        }

        @if (IsImporting)
        {
            <div style="padding: 10px; background: #fff3cd; border-radius: 3px; margin-top: 10px;">
                @LanguageService.GetText("import.statusInProgress", "Import in progress...")
            </div>
        }

        @if (!string.IsNullOrEmpty(ImportStatus))
        {
            <div style="padding: 10px; border-radius: 3px; margin-top: 10px;"
                class="@(ImportError ? "alert-error" : "alert-success")">
                @ImportStatus
            </div>
        }
    </div>
</div>

@code {
    private bool IsValidating = false;
    private bool ValidationCompleted = false;
    private bool ValidationPassed = false;
    private List<string> ValidationErrors = new();
    private int ImportedCount = 0;
    private int UpdatedCount = 0;
    private bool IsImporting = false;
    private string ImportStatus = string.Empty;
    private bool ImportError = false;
    private IBrowserFile? SelectedFile;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        SelectedFile = e.File;
    }

    private void ClearSelectedFile()
    {
        SelectedFile = null;
        ValidationCompleted = false;
        ValidationPassed = false;
        ValidationErrors.Clear();
        ImportStatus = string.Empty;
    }

    private async Task ValidateImportAsync()
    {
        if (SelectedFile == null) return;

        try
        {
            IsValidating = true;
            ValidationCompleted = false;

            using var stream = SelectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10 MB limit
            var validationResult = await RoomApiService.ValidateImportAsync(stream);

            ValidationPassed = validationResult.IsValid;
            ValidationErrors = validationResult.Errors ?? new();
            ImportedCount = validationResult.RoomsToImport;
            UpdatedCount = validationResult.RoomsToUpdate;
            ValidationCompleted = true;
        }
        catch (Exception ex)
        {
            ValidationErrors.Add(ex.Message);
            ValidationPassed = false;
            ValidationCompleted = true;
            Console.Error.WriteLine($"Validation error: {ex.Message}");
        }
        finally
        {
            IsValidating = false;
        }
    }

    private async Task ExecuteImportAsync()
    {
        if (SelectedFile == null || !ValidationPassed) return;

        try
        {
            IsImporting = true;
            ImportStatus = string.Empty;

            using var stream = SelectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var result = await RoomApiService.ExecuteImportAsync(stream, overwrite: false);

            if (result.Status == "success")
            {
                ImportStatus = LanguageService.GetText("import.statusCompleted", "Import completed successfully");
                ImportError = false;
            }
            else
            {
                ImportStatus = result.ErrorMessage ?? LanguageService.GetText("import.statusFailed", "Import failed. Please try again.");
                ImportError = true;
            }
        }
        catch (Exception ex)
        {
            ImportStatus = LanguageService.GetText("import.statusFailed", "Import failed. Please try again.");
            ImportError = true;
            Console.Error.WriteLine($"Import error: {ex.Message}");
        }
        finally
        {
            IsImporting = false;
        }
    }
}
