@page "/bookings"
@using System.Net.Http.Json
@inject HttpClient Http

<div class="container py-4">
  <h3>Bookings</h3>

  <div class="mb-3">
    <input class="form-control mb-2" placeholder="ClientId" @bind="newClientId" type="number" />
    <input class="form-control mb-2" placeholder="Arrival (YYYY-MM-DD)" @bind="newArrival" />
    <input class="form-control mb-2" placeholder="Departure (YYYY-MM-DD)" @bind="newDeparture" />
    <input class="form-control mb-2" placeholder="Status" @bind="newStatus" />
    <button class="btn btn-primary" @onclick="AddBooking">Add Booking</button>
  </div>

  @if (bookings is null)
  {
    <p><em>Loading...</em></p>
  }
  else
  {
    <table class="table table-striped">
      <thead><tr><th>Id</th><th>ClientId</th><th>Arrival</th><th>Departure</th><th>Status</th></tr></thead>
      <tbody>
        @foreach (var b in bookings)
        {
          <tr>
            <td>@b.Id</td>
            <td>@b.ClientId</td>
            <td>@b.ArrivalDate</td>
            <td>@b.DepartureDate</td>
            <td>@b.Status</td>
          </tr>
        }
      </tbody>
    </table>
  }
</div>

@code {
  private List<BookingItem>? bookings;
  private int newClientId;
  private string newArrival = "";
  private string newDeparture = "";
  private string newStatus = "Confirmed";

  protected override async Task OnInitializedAsync()
  {
    try { bookings = await Http.GetFromJsonAsync<List<BookingItem>>("/api/bookings"); } catch { }
  }

  private async Task AddBooking()
  {
    var toPost = new BookingItem(0, newClientId, newArrival, newDeparture, newStatus);
    try
    {
      var res = await Http.PostAsJsonAsync("/api/bookings", toPost);
      if (res.IsSuccessStatusCode)
      {
        var created = await res.Content.ReadFromJsonAsync<BookingItem>();
        if (created is not null) bookings ??= new(); bookings.Add(created);
        newClientId = 0; newArrival = newDeparture = string.Empty; newStatus = "Confirmed";
      }
    }
    catch { }
  }

  record BookingItem(int Id, int ClientId, string ArrivalDate, string DepartureDate, string Status);
}
