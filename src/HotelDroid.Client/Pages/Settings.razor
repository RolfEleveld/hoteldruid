@page "/settings"
@using HotelDroid.Client.Services
@inject ISettingApiService SettingApi

<PageTitle>Settings</PageTitle>

<div class="container-fluid assets-manager">
    <div class="row mb-3">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body d-flex align-items-center gap-2">
                    <label class="form-label mb-0">Filter by User ID:</label>
                    <input type="number" class="form-control" style="width:120px" @bind="filterUserId" @bind:event="oninput" />
                    <button class="btn btn-outline-primary btn-sm" @onclick="Load">Apply</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ClearFilter">Show All</button>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Settings</h5>
                    <button class="btn btn-success btn-sm w-100 mb-2" @onclick="AddNew"><span class="bi bi-plus"></span> Add Setting</button>
                    @if (items == null)
                    {
                        <div>Loading...</div>
                    }
                    else if (items.Count == 0)
                    {
                        <div class="alert alert-info">No settings defined.</div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var item in items)
                            {
                                <a class="list-group-item list-group-item-action @(IsSelected(item) ? "active" : "")" @onclick="() => SelectItem(item)">
                                    <div class="fw-semibold">@item.Key</div>
                                    <small class="text-muted">User @item.UserId</small>
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@((selectedKey == null) ? "New Setting" : $"Edit: {selectedKey}")</h5>
                    <div class="mb-3">
                        <label class="form-label">User ID <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" @bind="editModel.UserId" disabled="@(selectedKey != null)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Setting Key <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="editModel.Key" disabled="@(selectedKey != null)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">String Value</label>
                        <input class="form-control" @bind="editModel.StringValue" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Numeric Value</label>
                        <input type="number" class="form-control" @bind="editModel.NumericValue" />
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" @onclick="Save">Save</button>
                        @if (selectedKey != null)
                        {
                            <button class="btn btn-danger" @onclick="Delete">Delete</button>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger mt-2">@errorMessage</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Details</h5>
                    @if (selectedKey != null && selectedItem != null)
                    {
                        <dl class="row">
                            <dt class="col-5">Key</dt><dd class="col-7">@selectedItem.Key</dd>
                            <dt class="col-5">User ID</dt><dd class="col-7">@selectedItem.UserId</dd>
                            <dt class="col-5">Value</dt><dd class="col-7">@selectedItem.StringValue</dd>
                            <dt class="col-5">Num</dt><dd class="col-7">@selectedItem.NumericValue</dd>
                        </dl>
                    }
                    else
                    {
                        <div class="text-muted">Select a setting to view details</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<SettingDto>? items;
    private SettingDto? selectedItem;
    private string? selectedKey;  // composite key "userId_key"
    private EditModel editModel = new();
    private string? errorMessage;
    private int? filterUserId;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        if (filterUserId.HasValue)
            items = await SettingApi.GetByUserAsync(filterUserId.Value);
        else
            items = await SettingApi.GetAllAsync();
        StateHasChanged();
    }

    private async Task ClearFilter()
    {
        filterUserId = null;
        await Load();
    }

    private bool IsSelected(SettingDto item) =>
        selectedKey == $"{item.UserId}_{item.Key}";

    private void SelectItem(SettingDto item)
    {
        selectedItem = item;
        selectedKey = $"{item.UserId}_{item.Key}";
        editModel = EditModel.From(item);
        errorMessage = null;
    }

    private void AddNew()
    {
        selectedItem = null;
        selectedKey = null;
        editModel = new EditModel { UserId = filterUserId ?? 0 };
        errorMessage = null;
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(editModel.Key)) { errorMessage = "Setting key is required."; return; }
        errorMessage = null;
        var dto = editModel.ToDto();
        try
        {
            if (selectedKey == null)
                await SettingApi.UpsertAsync(dto);
            else
                await SettingApi.UpdateAsync(dto.UserId ?? 0, dto.Key ?? "", dto);
            await Load();
            // Re-select updated item
            selectedItem = items?.FirstOrDefault(x => x.Key == dto.Key && x.UserId == dto.UserId);
            selectedKey = selectedItem != null ? $"{selectedItem.UserId}_{selectedItem.Key}" : null;
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task Delete()
    {
        if (selectedItem == null) return;
        await SettingApi.DeleteAsync(selectedItem.UserId ?? 0, selectedItem.Key ?? "");
        selectedItem = null;
        selectedKey = null;
        await Load();
    }

    private class EditModel
    {
        public int UserId { get; set; }
        public string Key { get; set; } = string.Empty;
        public string? StringValue { get; set; }
        public int? NumericValue { get; set; }

        public SettingDto ToDto() => new(Key: Key, UserId: UserId, StringValue: StringValue, NumericValue: NumericValue);
        public static EditModel From(SettingDto dto) => new() { UserId = dto.UserId ?? 0, Key = dto.Key ?? string.Empty, StringValue = dto.StringValue, NumericValue = dto.NumericValue };
    }
}
