@page "/bookings"
@using Microsoft.AspNetCore.Components.Web
@using HotelDruid.Client.Services
@using HotelDruid.Shared
@inject IBookingApiService BookingApi
@inject IActiveYearService ActiveYearService

@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["bookings.title", "Bookings"]</PageTitle>
<div class="container-fluid">
    <div class="row align-items-center mb-2 mt-2">
        <div class="col-auto"><h5 class="mb-0">Bookings</h5></div>
        <div class="col-auto">
            <label class="me-1">Year:</label>
            <input class="form-control d-inline-block" type="number" @bind="filterYear" style="width:90px" />
            <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="ApplyFilter">Load</button>
        </div>
    </div>
    <div class="row">
        <div class="col-md-3 border-end">
            <button class="btn btn-sm btn-primary mb-2" @onclick="NewRecord">+ New</button>
            @if (records is null) { <p><em>@L["common.loading", "Loading..."]</em></p> }
            else if (records.Count == 0) { <p class="text-muted">No bookings</p> }
            else
            {
                <ul class="list-group">
                    @foreach (var r in records)
                    {
                        <li class="list-group-item list-group-item-action @(selected?.Id == r.Id ? "active" : "")"
                            style="cursor:pointer" @onclick="() => SelectRecord(r)">
                            <div class="fw-bold">@r.Year — @r.ClientId</div>
                            <small>@FormatDate(r.ArrivalDate) → @FormatDate(r.DepartureDate) (@r.Status)</small>
                        </li>
                    }
                </ul>
            }
        </div>
        <div class="col-md-6 border-end">
            @if (editing)
            {
                <h5 class="mt-1">@(isNew ? "New Booking" : "Edit Booking")</h5>
                <div class="row g-2">
                    <div class="col-6"><label>Year *</label><input class="form-control" type="number" @bind="form.Year" /></div>
                    <div class="col-6"><label>Client ID</label><input class="form-control" @bind="form.ClientId" /></div>
                    <div class="col-6"><label>Room ID</label><input class="form-control" @bind="form.RoomId" /></div>
                    <div class="col-6"><label>Status</label><input class="form-control" @bind="form.Status" /></div>
                    <div class="col-6"><label>Arrival Date</label><input class="form-control" type="date" @bind="form.ArrivalDate" /></div>
                    <div class="col-6"><label>Departure Date</label><input class="form-control" type="date" @bind="form.DepartureDate" /></div>
                    <div class="col-12"><label>Notes</label><input class="form-control" @bind="form.Notes" /></div>
                </div>
                @if (!string.IsNullOrEmpty(errorMsg)) { <div class="alert alert-danger mt-2">@errorMsg</div> }
                <div class="mt-3">
                    <button class="btn btn-primary me-2" @onclick="Save">@L["common.save", "Save"]</button>
                    <button class="btn btn-secondary" @onclick="Cancel">@L["common.cancel", "Cancel"]</button>
                </div>
            }
        </div>
        <div class="col-md-3">
            @if (selected is not null && !editing)
            {
                <h5 class="mt-1">@L["common.details", "Details"]</h5>
                <dl>
                    <dt>Year</dt><dd>@selected.Year</dd>
                    <dt>Client ID</dt><dd>@selected.ClientId</dd>
                    <dt>Room ID</dt><dd>@selected.RoomId</dd>
                    <dt>Status</dt><dd>@selected.Status</dd>
                    <dt>Arrival</dt><dd>@FormatDate(selected.ArrivalDate)</dd>
                    <dt>Departure</dt><dd>@FormatDate(selected.DepartureDate)</dd>
                    <dt>Notes</dt><dd>@selected.Notes</dd>
                </dl>
                <button class="btn btn-sm btn-outline-primary me-1" @onclick="EditSelected">Edit</button>
                <button class="btn btn-sm btn-outline-warning me-1" @onclick="CancelBooking">Cancel Booking</button>
                <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelected">@L["common.delete", "Delete"]</button>
            }
        </div>
    </div>
</div>

@code {
    private List<BookingDto>? records;
    private BookingDto? selected;
    private bool editing, isNew;
    private string errorMsg = "";
    private int? filterYear;
    private FormModel form = new();

    protected override async Task OnInitializedAsync()
    {
        filterYear = ActiveYearService.CurrentYear;
        await LoadAll();
    }

    private async Task LoadAll() => records = await BookingApi.ListAsync(filterYear);
    private async Task ApplyFilter() => await LoadAll();

    private void NewRecord() { form = new() { Year = filterYear ?? ActiveYearService.CurrentYear }; isNew = true; editing = true; selected = null; errorMsg = ""; }
    private void SelectRecord(BookingDto r) { selected = r; editing = false; }
    private void EditSelected()
    {
        if (selected is null) return;
        form = new() { Year = selected.Year, ClientId = selected.ClientId, RoomId = selected.RoomId, Status = selected.Status, ArrivalDate = selected.ArrivalDate, DepartureDate = selected.DepartureDate, Notes = selected.Notes };
        isNew = false; editing = true; errorMsg = "";
    }

    private async Task Save()
    {
        if (form.Year == 0) { errorMsg = "Year is required."; return; }
        var dto = new BookingDto(selected?.Id, form.Year, form.ClientId, form.RoomId, form.ArrivalDate, form.DepartureDate, form.Status, form.Notes);
        try
        {
            if (isNew) await BookingApi.CreateAsync(dto);
            else await BookingApi.UpdateAsync(selected!.Year, selected.Id!, dto);
            editing = false;
            await LoadAll();
        }
        catch { errorMsg = "Save failed."; }
    }

    private void Cancel() { editing = false; errorMsg = ""; }

    private async Task CancelBooking()
    {
        if (selected?.Id is null) return;
        try { await BookingApi.CancelAsync(selected.Year, selected.Id); selected = null; await LoadAll(); }
        catch { errorMsg = "Cancel failed."; }
    }

    private async Task DeleteSelected()
    {
        if (selected?.Id is null) return;
        try { await BookingApi.DeleteAsync(selected.Year, selected.Id); selected = null; await LoadAll(); }
        catch { errorMsg = "Delete failed."; }
    }

    private class FormModel
    {
        public int Year { get; set; }
        public string? ClientId { get; set; }
        public string? RoomId { get; set; }
        public string? Status { get; set; }
        public DateOnly? ArrivalDate { get; set; }
        public DateOnly? DepartureDate { get; set; }
        public string? Notes { get; set; }
    }

    private static string FormatDate(DateOnly? date) => date?.ToString("yyyy-MM-dd") ?? "-";
}



