@page "/expenses"
@using HotelDruid.Client.Services
@inject IExpenseApiService ExpenseApi

@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["expenses.title", "Expenses"]</PageTitle>
<div class="container-fluid">
    <div class="row align-items-center mb-2 mt-2">
        <div class="col-auto"><h5 class="mb-0">Expenses</h5></div>
        <div class="col-auto">
            <label class="me-1">Year:</label>
            <input class="form-control d-inline-block" type="number" @bind="filterYear" style="width:90px" />
            <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="ApplyFilter">Load</button>
        </div>
    </div>
    <div class="row">
        <div class="col-md-3 border-end">
            <button class="btn btn-sm btn-primary mb-2" @onclick="NewRecord">+ New</button>
            @if (records is null) { <p><em>@L["common.loading", "Loading..."]</em></p> }
            else if (records.Count == 0) { <p class="text-muted">No expenses</p> }
            else
            {
                <ul class="list-group">
                    @foreach (var r in records)
                    {
                        <li class="list-group-item list-group-item-action @(selected?.Id == r.Id ? "active" : "")"
                            style="cursor:pointer" @onclick="() => SelectRecord(r)">
                            <div class="fw-bold">@r.Year — @r.Date</div>
                            <small>@r.Description (@r.Amount)</small>
                        </li>
                    }
                </ul>
            }
        </div>
        <div class="col-md-6 border-end">
            @if (editing)
            {
                <h5 class="mt-1">@(isNew ? "New Expense" : "Edit Expense")</h5>
                <div class="row g-2">
                    <div class="col-6"><label>Year *</label><input class="form-control" type="number" @bind="form.Year" /></div>
                    <div class="col-6"><label>Cash Register ID</label><input class="form-control" @bind="form.CashRegisterId" /></div>
                    <div class="col-6"><label>Amount</label><input class="form-control" type="number" @bind="form.Amount" /></div>
                    <div class="col-6"><label>Date</label><input class="form-control" placeholder="YYYY-MM-DD" @bind="form.Date" /></div>
                    <div class="col-12"><label>Description</label><input class="form-control" @bind="form.Description" /></div>
                </div>
                @if (!string.IsNullOrEmpty(errorMsg)) { <div class="alert alert-danger mt-2">@errorMsg</div> }
                <div class="mt-3">
                    <button class="btn btn-primary me-2" @onclick="Save">@L["common.save", "Save"]</button>
                    <button class="btn btn-secondary" @onclick="Cancel">@L["common.cancel", "Cancel"]</button>
                </div>
            }
        </div>
        <div class="col-md-3">
            @if (selected is not null && !editing)
            {
                <h5 class="mt-1">@L["common.details", "Details"]</h5>
                <dl>
                    <dt>Year</dt><dd>@selected.Year</dd>
                    <dt>Cash Register</dt><dd>@selected.CashRegisterId</dd>
                    <dt>Amount</dt><dd>@selected.Amount</dd>
                    <dt>Date</dt><dd>@selected.Date</dd>
                    <dt>Description</dt><dd>@selected.Description</dd>
                </dl>
                <button class="btn btn-sm btn-outline-primary me-1" @onclick="EditSelected">Edit</button>
                <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelected">@L["common.delete", "Delete"]</button>
            }
        </div>
    </div>
</div>

@code {
    private List<ExpenseClientDto>? records;
    private ExpenseClientDto? selected;
    private bool editing, isNew;
    private string errorMsg = "";
    private int? filterYear;
    private FormModel form = new();

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task LoadAll() => records = await ExpenseApi.ListAsync(filterYear);
    private async Task ApplyFilter() => await LoadAll();

    private void NewRecord() { form = new() { Year = filterYear ?? DateTime.Now.Year }; isNew = true; editing = true; selected = null; errorMsg = ""; }
    private void SelectRecord(ExpenseClientDto r) { selected = r; editing = false; }
    private void EditSelected()
    {
        if (selected is null) return;
        form = new() { Year = selected.Year, CashRegisterId = selected.CashRegisterId, Amount = selected.Amount, Date = selected.Date, Description = selected.Description };
        isNew = false; editing = true; errorMsg = "";
    }

    private async Task Save()
    {
        if (form.Year == 0) { errorMsg = "Year is required."; return; }
        var dto = new ExpenseClientDto(selected?.Id, form.Year, form.CashRegisterId, form.Amount, form.Description, form.Date);
        try
        {
            if (isNew) await ExpenseApi.CreateAsync(dto);
            else await ExpenseApi.UpdateAsync(selected!.Year, selected.Id!, dto);
            editing = false;
            await LoadAll();
        }
        catch { errorMsg = "Save failed."; }
    }

    private void Cancel() { editing = false; errorMsg = ""; }

    private async Task DeleteSelected()
    {
        if (selected?.Id is null) return;
        try { await ExpenseApi.DeleteAsync(selected.Year, selected.Id); selected = null; await LoadAll(); }
        catch { errorMsg = "Delete failed."; }
    }

    private class FormModel
    {
        public int Year { get; set; }
        public string? CashRegisterId { get; set; }
        public double? Amount { get; set; }
        public string? Date { get; set; }
        public string? Description { get; set; }
    }
}


