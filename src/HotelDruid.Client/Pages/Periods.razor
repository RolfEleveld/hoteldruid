@page "/periods"
@using HotelDruid.Client.Services
@inject IPeriodApiService PeriodApi

@inject ILanguageService LanguageService

<PageTitle>@LanguageService.GetText("periods.title", "Periods")</PageTitle>
<div class="container-fluid">
    <div class="row align-items-center mb-2 mt-2">
        <div class="col-auto"><h5 class="mb-0">Periods</h5></div>
        <div class="col-auto">
            <label class="me-1">Year:</label>
            <input class="form-control d-inline-block" type="number" @bind="filterYear" style="width:90px" />
            <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="ApplyFilter">Load</button>
        </div>
    </div>
    <div class="row">
        <div class="col-md-3 border-end">
            <button class="btn btn-sm btn-primary mb-2" @onclick="NewRecord">+ New</button>
            @if (records is null) { <p><em>@LanguageService.GetText("common.loading", "Loading...")</em></p> }
            else if (records.Count == 0) { <p class="text-muted">No periods</p> }
            else
            {
                <ul class="list-group">
                    @foreach (var r in records)
                    {
                        <li class="list-group-item list-group-item-action @(selected?.Id == r.Id ? "active" : "")"
                            style="cursor:pointer" @onclick="() => SelectRecord(r)">
                            <div class="fw-bold">@r.Year</div>
                            <small>@r.StartDate → @r.EndDate</small>
                        </li>
                    }
                </ul>
            }
        </div>
        <div class="col-md-6 border-end">
            @if (editing)
            {
                <h5 class="mt-1">@(isNew ? "New Period" : "Edit Period")</h5>
                <div class="row g-2">
                    <div class="col-6"><label>Year *</label><input class="form-control" type="number" @bind="form.Year" /></div>
                    <div class="col-6"><label>Start Date</label><input class="form-control" placeholder="yyyy-MM-dd" @bind="form.StartDate" /></div>
                    <div class="col-6"><label>End Date</label><input class="form-control" placeholder="yyyy-MM-dd" @bind="form.EndDate" /></div>
                    <div class="col-6"><label>Tariff 1</label><input class="form-control" type="number" step="0.01" @bind="form.Tariff1" /></div>
                    <div class="col-6"><label>Tariff 1 / Person</label><input class="form-control" type="number" step="0.01" @bind="form.Tariff1PerPerson" /></div>
                </div>
                @if (!string.IsNullOrEmpty(errorMsg)) { <div class="alert alert-danger mt-2">@errorMsg</div> }
                <div class="mt-3">
                    <button class="btn btn-primary me-2" @onclick="Save">@LanguageService.GetText("common.save", "Save")</button>
                    <button class="btn btn-secondary" @onclick="Cancel">@LanguageService.GetText("common.cancel", "Cancel")</button>
                </div>
            }
        </div>
        <div class="col-md-3">
            @if (selected is not null && !editing)
            {
                <h5 class="mt-1">@LanguageService.GetText("common.details", "Details")</h5>
                <dl>
                    <dt>Year</dt><dd>@selected.Year</dd>
                    <dt>Start Date</dt><dd>@selected.StartDate</dd>
                    <dt>End Date</dt><dd>@selected.EndDate</dd>
                    <dt>Tariff 1</dt><dd>@selected.Tariff1</dd>
                    <dt>Tariff 1/Person</dt><dd>@selected.Tariff1PerPerson</dd>
                </dl>
                <button class="btn btn-sm btn-outline-primary me-1" @onclick="EditSelected">Edit</button>
                <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelected">@LanguageService.GetText("common.delete", "Delete")</button>
            }
        </div>
    </div>
</div>

@code {
    private List<PeriodDto>? records;
    private PeriodDto? selected;
    private bool editing, isNew;
    private string errorMsg = "";
    private int? filterYear;
    private FormModel form = new();

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task LoadAll() => records = await PeriodApi.ListAsync(filterYear);
    private async Task ApplyFilter() => await LoadAll();

    private void NewRecord() { form = new() { Year = filterYear ?? DateTime.Now.Year }; isNew = true; editing = true; selected = null; errorMsg = ""; }
    private void SelectRecord(PeriodDto r) { selected = r; editing = false; }
    private void EditSelected()
    {
        if (selected is null) return;
        form = new() { Year = selected.Year, StartDate = selected.StartDate, EndDate = selected.EndDate, Tariff1 = selected.Tariff1, Tariff1PerPerson = selected.Tariff1PerPerson };
        isNew = false; editing = true; errorMsg = "";
    }

    private async Task Save()
    {
        if (form.Year == 0) { errorMsg = "Year is required."; return; }
        var dto = new PeriodDto(selected?.Id, form.Year, form.StartDate, form.EndDate, form.Tariff1, form.Tariff1PerPerson);
        try
        {
            if (isNew) await PeriodApi.CreateAsync(dto);
            else await PeriodApi.UpdateAsync(selected!.Year, selected.Id!, dto);
            editing = false;
            await LoadAll();
        }
        catch { errorMsg = "Save failed."; }
    }

    private void Cancel() { editing = false; errorMsg = ""; }

    private async Task DeleteSelected()
    {
        if (selected?.Id is null) return;
        try { await PeriodApi.DeleteAsync(selected.Year, selected.Id); selected = null; await LoadAll(); }
        catch { errorMsg = "Delete failed."; }
    }

    private class FormModel
    {
        public int Year { get; set; }
        public string? StartDate { get; set; }
        public string? EndDate { get; set; }
        public double? Tariff1 { get; set; }
        public double? Tariff1PerPerson { get; set; }
    }
}

