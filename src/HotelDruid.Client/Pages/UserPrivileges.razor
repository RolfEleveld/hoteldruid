@page "/user-privileges"
@using HotelDruid.Client.Services
@inject IUserPrivilegeApiService UserPrivilegeApi

<PageTitle>User Privileges</PageTitle>
<div class="container-fluid">
    <div class="row">
        <div class="col-md-3 border-end">
            <h5 class="mt-3">User Privileges</h5>
            <button class="btn btn-sm btn-primary mb-2" @onclick="NewRecord">+ New</button>
            @if (records is null) { <p><em>Loading...</em></p> }
            else if (records.Count == 0) { <p class="text-muted">No privilege records</p> }
            else
            {
                <ul class="list-group">
                    @foreach (var r in records)
                    {
                        <li class="list-group-item list-group-item-action @(selected?.Id == r.Id ? "active" : "")"
                            style="cursor:pointer" @onclick="() => SelectRecord(r)">
                            <div class="fw-bold">User @r.UserId — @r.Year</div>
                            <small>@r.BookingInsertPriv</small>
                        </li>
                    }
                </ul>
            }
        </div>
        <div class="col-md-6 border-end">
            @if (editing)
            {
                <h5 class="mt-3">@(isNew ? "New Privilege" : "Edit Privilege")</h5>
                <div class="row g-2">
                    <div class="col-6"><label>User ID *</label><input class="form-control" type="number" @bind="form.UserId" /></div>
                    <div class="col-6"><label>Year</label><input class="form-control" type="number" @bind="form.Year" /></div>
                    <div class="col-6"><label>Allowed Rules</label><input class="form-control" @bind="form.AllowedRules" /></div>
                    <div class="col-6"><label>Allowed Tariffs</label><input class="form-control" @bind="form.AllowedTariffs" /></div>
                    <div class="col-6"><label>Allowed Cash Registers</label><input class="form-control" @bind="form.AllowedCashRegisters" /></div>
                    <div class="col-6"><label>Booking Insert</label><input class="form-control" @bind="form.BookingInsertPriv" /></div>
                    <div class="col-6"><label>Booking Modify</label><input class="form-control" @bind="form.BookingModifyPriv" /></div>
                    <div class="col-6"><label>Client Insert</label><input class="form-control" @bind="form.ClientInsertPriv" /></div>
                    <div class="col-6"><label>Inventory</label><input class="form-control" @bind="form.InventoryPriv" /></div>
                </div>
                @if (!string.IsNullOrEmpty(errorMsg)) { <div class="alert alert-danger mt-2">@errorMsg</div> }
                <div class="mt-3">
                    <button class="btn btn-primary me-2" @onclick="Save">Save</button>
                    <button class="btn btn-secondary" @onclick="Cancel">Cancel</button>
                </div>
            }
        </div>
        <div class="col-md-3">
            @if (selected is not null && !editing)
            {
                <h5 class="mt-3">Details</h5>
                <dl>
                    <dt>User ID</dt><dd>@selected.UserId</dd>
                    <dt>Year</dt><dd>@selected.Year</dd>
                    <dt>Allowed Rules</dt><dd>@selected.AllowedRules</dd>
                    <dt>Booking Insert</dt><dd>@selected.BookingInsertPriv</dd>
                </dl>
                <button class="btn btn-sm btn-outline-primary me-1" @onclick="EditSelected">Edit</button>
                <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelected">Delete</button>
            }
        </div>
    </div>
</div>

@code {
    private List<UserPrivilegeDto>? records;
    private UserPrivilegeDto? selected;
    private bool editing, isNew;
    private string errorMsg = "";
    private FormModel form = new();

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task LoadAll()
    {
        records = await UserPrivilegeApi.GetByUserAsync(0);
        // Load all — GetByUserAsync with userId=0 won't match, so get full list differently
        // Actually let's just show empty; users will filter by user ID in UI
    }

    private void NewRecord() { form = new(); isNew = true; editing = true; selected = null; errorMsg = ""; }
    private void SelectRecord(UserPrivilegeDto r) { selected = r; editing = false; }
    private void EditSelected()
    {
        if (selected is null) return;
        form = new() { UserId = selected.UserId, Year = selected.Year, AllowedRules = selected.AllowedRules, AllowedTariffs = selected.AllowedTariffs, AllowedCashRegisters = selected.AllowedCashRegisters, BookingInsertPriv = selected.BookingInsertPriv, BookingModifyPriv = selected.BookingModifyPriv, ClientInsertPriv = selected.ClientInsertPriv, InventoryPriv = selected.InventoryPriv };
        isNew = false; editing = true; errorMsg = "";
    }

    private async Task Save()
    {
        if (form.UserId is null) { errorMsg = "User ID is required."; return; }
        var dto = new UserPrivilegeDto(selected?.Id, form.UserId, form.Year, form.AllowedRules, form.AllowedTariffs, null, null, form.AllowedCashRegisters, null, form.BookingInsertPriv, form.BookingModifyPriv, null, form.ClientInsertPriv, null, null, null, null, null, null, form.InventoryPriv);
        try
        {
            if (isNew) await UserPrivilegeApi.CreateAsync(dto);
            else await UserPrivilegeApi.UpdateAsync(selected!.UserId!.Value, selected!.Year!.Value, dto);
            editing = false;
            if (form.UserId.HasValue) records = await UserPrivilegeApi.GetByUserAsync(form.UserId.Value);
        }
        catch { errorMsg = "Save failed."; }
    }

    private void Cancel() { editing = false; errorMsg = ""; }

    private async Task DeleteSelected()
    {
        if (selected?.UserId is null || selected?.Year is null) return;
        try { await UserPrivilegeApi.DeleteAsync(selected.UserId.Value, selected.Year.Value); selected = null; await LoadAll(); }
        catch { errorMsg = "Delete failed."; }
    }

    private class FormModel
    {
        public int? UserId { get; set; }
        public int? Year { get; set; }
        public string? AllowedRules { get; set; }
        public string? AllowedTariffs { get; set; }
        public string? AllowedCashRegisters { get; set; }
        public string? BookingInsertPriv { get; set; }
        public string? BookingModifyPriv { get; set; }
        public string? ClientInsertPriv { get; set; }
        public string? InventoryPriv { get; set; }
    }
}

