@page "/user-groups"
@using HotelDruid.Client.Services
@inject IUserGroupApiService UserGroupApi

@inject ILanguageService LanguageService

<PageTitle>@LanguageService.GetText("userGroups.title", "User Groups")</PageTitle>

<div class="container-fluid assets-manager">
    <div class="row">
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@LanguageService.GetText("userGroups.title", "User Groups")</h5>
                    <button class="btn btn-success btn-sm w-100 mb-2" @onclick="AddNew"><span class="bi bi-plus"></span> Add Group</button>
                    @if (items == null)
                    {
                        <div>@LanguageService.GetText("common.loading", "Loading...")</div>
                    }
                    else if (items.Count == 0)
                    {
                        <div class="alert alert-info">@LanguageService.GetText("userGroups.emptyList", "No user groups defined.")</div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var item in items)
                            {
                                <a class="list-group-item list-group-item-action @(selected?.Id == item.Id ? "active" : "")" @onclick="() => Select(item)">@item.Name</a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@LanguageService.GetText("userGroups.title", "User Groups")</h5>
                    <div class="mb-3">
                        <label class="form-label">Group Name <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="editModel.Name" />
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" @onclick="Save">@LanguageService.GetText("common.save", "Save")</button>
                        @if (selected != null)
                        {
                            <button class="btn btn-danger" @onclick="Delete">@LanguageService.GetText("common.delete", "Delete")</button>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger mt-2">@errorMessage</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@LanguageService.GetText("userGroups.title", "User Groups")</h5>
                    @if (selected != null)
                    {
                        <dl class="row">
                            <dt class="col-4">ID</dt><dd class="col-8">@selected.Id</dd>
                            <dt class="col-4">Name</dt><dd class="col-8">@selected.Name</dd>
                        </dl>
                    }
                    else
                    {
                        <div class="text-muted">Select a group to view details</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<UserGroupDto>? items;
    private UserGroupDto? selected;
    private EditModel editModel = new();
    private string? errorMessage;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        items = await UserGroupApi.GetAllAsync();
        StateHasChanged();
    }

    private void Select(UserGroupDto item)
    {
        selected = item;
        editModel = EditModel.From(item);
        errorMessage = null;
    }

    private void AddNew()
    {
        selected = null;
        editModel = new EditModel();
        errorMessage = null;
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(editModel.Name)) { errorMessage = "Name is required."; return; }
        errorMessage = null;
        var dto = editModel.ToDto();
        try
        {
            if (selected == null) await UserGroupApi.CreateAsync(dto);
            else await UserGroupApi.UpdateAsync(selected.Id, dto);
            await Load();
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task Delete()
    {
        if (selected == null) return;
        await UserGroupApi.DeleteAsync(selected.Id);
        selected = null;
        await Load();
    }

    private class EditModel
    {
        public string Name { get; set; } = string.Empty;

        public UserGroupDto ToDto() => new(Id: string.Empty, Name: Name);
        public static EditModel From(UserGroupDto dto) => new() { Name = dto.Name ?? string.Empty };
    }
}

