@page "/rooms"
@using System.Net.Http.Json
@using System.Text.RegularExpressions
@using System.Text.Json
@using HotelDruid.Shared
@inject HttpClient Http
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResource> L
@implements IAsyncDisposable

<PageTitle>@L["rooms.title", "Top Rooms"]</PageTitle>

<div class="container-fluid rooms-manager">
    <div class="row g-3 h-100">
        <!-- LEFT PANEL: Room List -->
        <div class="col-md-3">
            <div class="panel panel-default h-100 d-flex flex-column">
                <div class="panel-heading">
                    <h3 class="panel-title">@L["rooms.title", "Top Rooms"]</h3>
                </div>
                <div class="panel-body flex-grow-1 overflow-auto">
                    <button class="btn btn-success btn-sm w-100 mb-3" @onclick="AddNewRoom">
                        <span class="bi bi-plus"></span> @L["rooms.add", "Add Room"]
                    </button>

                    @if (rooms == null)
                    {
                        <div class="spinner-border spinner-border-sm" role="status">
                            <span class="visually-hidden">@L["common.loading", "Loading..."]</span>
                        </div>
                    }
                    else if (rooms.Count == 0)
                    {
                        <div class="alert alert-info">@L["rooms.emptyList", "No rooms available"]</div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var room in rooms)
                            {
                                <button type="button"
                                    class="list-group-item list-group-item-action @(selectedRoom?.Name == room.Name ? "active" : "")"
                                    @onclick="() => SelectRoom(room)">
                                    <div class="d-flex justify-content-between">
                                        <span>@room.Name</span>
                                        <small class="text-muted">@L["rooms.capacityPeople", room.Capacity]</small>
                                    </div>
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- CENTER PANEL: Room Details Editor -->
        <div class="col-md-5">
            @if (editModel is not null)
            {
                <div class="panel panel-default h-100 d-flex flex-column">
                    <div class="panel-heading">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h3 class="panel-title mb-0">
                                    @if (string.IsNullOrEmpty(editModel.Name))
                                    {
                                        <span>@L["rooms.newRoom", "New Room"]</span>
                                    }
                                    else
                                    {
                                        <span>@editModel.Name</span>
                                    }
                                </h3>
                                <small class="text-muted">@L["rooms.manageRoom", "Manage the room"]</small>
                            </div>
                            <div class="status-badge" title="@statusMessage">
                                @if (isSaving)
                                {
                                    <span class="badge bg-warning"><span class="spinner-border spinner-border-sm me-1"></span>@L["common.saving", "Saving..."]</span>
                                }
                                else if (!string.IsNullOrEmpty(lastError))
                                {
                                    <span class="badge bg-danger" title="@lastError">@L["common.error", "Error"]</span>
                                }
                                else if (!string.IsNullOrEmpty(lastWarning))
                                {
                                    <span class="badge bg-warning" title="@lastWarning">@L["common.warning", "Warning"]</span>
                                }
                                else if (isSaved)
                                {
                                    <span class="badge bg-success">@L["common.saved", "Saved"]</span>
                                }
                                else
                                {
                                    <span class="badge bg-info">@L["common.unsaved", "Unsaved changes"]</span>
                                }
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(lastError))
                        {
                            <div class="alert alert-danger alert-sm mt-2 mb-0">@lastError</div>
                        }
                        @if (!string.IsNullOrEmpty(lastWarning))
                        {
                            <div class="alert alert-warning alert-sm mt-2 mb-0">@lastWarning</div>
                        }
                    </div>

                    <div class="panel-body flex-grow-1 overflow-auto">
                        <form>
                            <div class="mb-3">
                                <label class="form-label">@L["rooms.nameLabel", "Room Name / ID"] <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" @bind="editModel.Name" 
                                    @bind:event="oninput" @onchange="() => OnFieldChanged()" disabled="@(editModel.Id is not null)" />
                                <small class="form-text text-muted">@L["rooms.nameHelp", "Unique identifier (e.g., 101, Suite-A)"]</small>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">@L["rooms.capacityLabel", "Capacity"] <span class="text-danger">*</span></label>
                                <input type="number" class="form-control" @bind="editModel.Capacity" 
                                    @bind:event="oninput" @onchange="() => OnFieldChanged()" min="1" />
                                <small class="form-text text-muted">@L["rooms.capacityHelp", "Max occupants"]</small>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">@L["rooms.floorNumber", "Floor Number"]</label>
                                    <input type="text" class="form-control" @bind="editModel.FloorNumber" 
                                        @bind:event="oninput" @onchange="() => OnFieldChanged()" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">@L["rooms.houseNumber", "House Number"]</label>
                                    <input type="text" class="form-control" @bind="editModel.HouseNumber" 
                                        @bind:event="oninput" @onchange="() => OnFieldChanged()" />
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">@L["rooms.priorityLabel", "Priority"]</label>
                                    <input type="number" class="form-control" @bind="editModel.Priority" 
                                        @bind:event="oninput" @onchange="() => OnFieldChanged()" />
                                    <small class="form-text text-muted">@L["rooms.priorityHelp", "Booking priority (lower = higher)"]</small>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">@L["rooms.secondaryPriorityLabel", "Secondary Priority"]</label>
                                    <input type="number" class="form-control" @bind="editModel.SecondaryPriority" 
                                        @bind:event="oninput" @onchange="() => OnFieldChanged()" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">@L["rooms.hasBedsLabel", "Has Beds"]</label>
                                <select class="form-select" @bind="editModel.HasBeds">
                                    <option value="">@L["rooms.selectOption", "Select..."]</option>
                                    <option value="S">@L["common.yes", "Yes"]</option>
                                    <option value="N">@L["common.no", "No"]</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">@L["rooms.commentsLabel", "Comments"]</label>
                                <textarea class="form-control" @bind="editModel.Comments" 
                                    @bind:event="oninput" @onchange="() => OnFieldChanged()" rows="3"></textarea>
                            </div>
                        </form>
                    </div>

                    <div class="panel-footer">
                        <div class="btn-group w-100" role="group">
                            <button type="button" class="btn btn-primary flex-grow-1" @onclick="SaveRoom" disabled="@isSaving">
                                <span class="bi bi-download"></span> @L["common.save", "Save"]
                            </button>
                            @if (editModel.Id is not null)
                            {
                                <button type="button" class="btn btn-info flex-grow-1" @onclick="DuplicateRoom">
                                    <span class="bi bi-files"></span> @L["rooms.duplicate", "Duplicate"]
                                </button>
                                <button type="button" class="btn btn-danger flex-grow-1" @onclick="DeleteRoom">
                                    <span class="bi bi-trash"></span> @L["common.delete", "Delete"]
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="panel panel-default h-100 d-flex align-items-center justify-content-center">
                    <div class="panel-body text-center text-muted">
                        <p class="mb-2"><span class="bi bi-arrow-left" style="font-size: 2rem;"></span></p>
                        <p>@L["rooms.selectPrompt", "Select a room from the list or add a new one"]</p>
                    </div>
                </div>
            }
        </div>

        <!-- RIGHT PANEL: Neighboring Rooms Matrix -->
        <div class="col-md-4">
            <div class="panel panel-default h-100 d-flex flex-column">
                <div class="panel-heading">
                    <h3 class="panel-title">
                        <span class="bi bi-diagram-2"></span> @L["rooms.neighboringRooms", "Neighboring Rooms"]
                    </h3>
                </div>
                <div class="panel-body flex-grow-1 overflow-auto">
                    @if (rooms is null || rooms.Count == 0)
                    {
                        <div class="alert alert-info">@L["rooms.emptyList", "No rooms available"]</div>
                    }
                    else if (rooms.Count == 1)
                    {
                        <div class="alert alert-info">@L["rooms.selectForNeighbors", "Create or select a room to edit neighbors"]</div>
                    }
                    else
                    {
                        <div class="neighbors-matrix">
                            <div class="matrix-header">
                                <div class="matrix-corner"></div>
                                @for (var colIndex = 0; colIndex < rooms.Count; colIndex++)
                                {
                                    var room = rooms[colIndex];
                                    <div class="matrix-label-col">@room.Name</div>
                                }
                            </div>

                            @for (var rowIndex = 0; rowIndex < rooms.Count; rowIndex++)
                            {
                                var rowRoom = rooms[rowIndex];
                                <div class="matrix-row">
                                    <div class="matrix-label-row">@rowRoom.Name</div>
                                    @for (var colIndex = 0; colIndex < rooms.Count; colIndex++)
                                    {
                                        var colRoom = rooms[colIndex];
                                        var isEditableCell = rowIndex > colIndex;
                                        var isNeighbor = isEditableCell && AreNeighbors(rowRoom, colRoom);

                                        <div class="matrix-cell">
                                            @if (isEditableCell)
                                            {
                                                <input type="checkbox" class="form-check-input"
                                                    checked="@isNeighbor"
                                                    @onchange="e => UpdateNeighborPair(rowRoom, colRoom, (bool)(e.Value ?? false))" />
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.rooms-manager {
    height: calc(100vh - 100px);
}

.panel {
    border: 1px solid #ddd;
    border-radius: 4px;
    box-shadow: 0 1px 1px rgba(0,0,0,.05);
}

.panel-heading {
    background-color: #f5f5f5;
    border-bottom: 1px solid #ddd;
    padding: 10px 15px;
}

.panel-body {
    padding: 15px;
}

.panel-footer {
    background-color: #f5f5f5;
    border-top: 1px solid #ddd;
    padding: 10px 15px;
}

.status-badge {
    display: flex;
    gap: 5px;
}

.alert-sm {
    padding: 8px 12px;
    margin-bottom: 0;
    font-size: 0.875rem;
}

.neighbors-matrix {
    display: grid;
    gap: 2px;
    font-size: 0.875rem;
}

.matrix-header,
.matrix-row {
    display: grid;
    grid-template-columns: 80px repeat(auto-fit, minmax(50px, 1fr));
    gap: 2px;
}

.matrix-corner,
.matrix-label-col,
.matrix-label-row {
    background-color: #f0f0f0;
    padding: 8px 4px;
    text-align: center;
    font-weight: bold;
    border: 1px solid #ddd;
    min-height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.matrix-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #ddd;
    background-color: #f9f9f9;
    min-height: 40px;
}

.matrix-cell:has(input[type="checkbox"]) {
    background-color: white;
}

.matrix-cell input[type="checkbox"] {
    cursor: pointer;
    transform: scale(1.2);
}

.list-group-item {
    cursor: pointer;
}

.btn-group > .btn {
    border-radius: 0;
}

.btn-group > .btn:first-child {
    border-radius: 4px 0 0 4px;
}

.btn-group > .btn:last-child {
    border-radius: 0 4px 4px 0;
}
</style>

@code {
    private List<RoomDto>? rooms;
    private RoomDto? selectedRoom;
    private RoomEditModel? editModel;
    private bool isSaving = false;
    private bool isSaved = true;
    private string? lastError;
    private string? lastWarning;
    private string statusMessage = string.Empty;
    private System.Timers.Timer? autoSaveTimer;
    private bool hasUnsavedChanges = false;

    // Mutable model for editing room properties
    private class RoomEditModel
    {
        public string? Id { get; set; }
        public string Name { get; set; } = "";
        public int Capacity { get; set; } = 1;
        public string? FloorNumber { get; set; }
        public string? HouseNumber { get; set; }
        public int? Priority { get; set; }
        public int? SecondaryPriority { get; set; }
        public string? HasBeds { get; set; }
        public string? NeighboringRooms { get; set; }
        public string? Comments { get; set; }

        public RoomDto ToDto()
        {
            return new RoomDto(Id, Name, Capacity, FloorNumber, HouseNumber, 
                Priority, SecondaryPriority, HasBeds, NeighboringRooms, Comments);
        }

        public static RoomEditModel FromDto(RoomDto dto)
        {
            return new RoomEditModel
            {
                Id = dto.Id,
                Name = dto.Name ?? "",
                Capacity = dto.Capacity,
                FloorNumber = dto.FloorNumber,
                HouseNumber = dto.HouseNumber,
                Priority = dto.Priority,
                SecondaryPriority = dto.SecondaryPriority,
                HasBeds = dto.HasBeds,
                NeighboringRooms = dto.NeighboringRooms,
                Comments = dto.Comments
            };
        }
    }

    protected override async Task OnInitializedAsync()
    {
        statusMessage = L["common.noChanges", "No changes"];
        await LoadRooms();
        initAutoSaveTimer();
    }

    private void initAutoSaveTimer()
    {
        autoSaveTimer = new System.Timers.Timer(1500);
        autoSaveTimer.Elapsed += async (s, e) =>
        {
            if (hasUnsavedChanges && selectedRoom != null && !isSaving)
            {
                await SaveRoom();
            }
        };
        autoSaveTimer.AutoReset = false;
    }

    private async Task LoadRooms()
    {
        try
        {
            rooms = (await Http.GetFromJsonAsync<List<RoomDto>>("/api/rooms") ?? new())
                .OrderBy(room => room.Name, NaturalRoomNameComparer.Instance)
                .ThenBy(room => room.Id, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
        catch (Exception ex)
        {
            lastError = string.Format(L["rooms.loadFailed", "Failed to load rooms: {0}"], ex.Message);
        }
    }

    private void SelectRoom(RoomDto room)
    {
        selectedRoom = room;
        editModel = RoomEditModel.FromDto(room);
        isSaved = true;
        hasUnsavedChanges = false;
        lastError = null;
        lastWarning = null;
        ClearAutoSaveTimer();
    }

    private void AddNewRoom()
    {
        selectedRoom = null;
        editModel = new RoomEditModel();
        isSaved = false;
        hasUnsavedChanges = false;
        lastError = null;
        lastWarning = null;
    }

    private void OnFieldChanged()
    {
        isSaved = false;
        hasUnsavedChanges = true;
        statusMessage = L["common.unsaved", "Unsaved changes"];
        autoSaveTimer?.Stop();
        autoSaveTimer?.Start();
    }

    private void ClearAutoSaveTimer()
    {
        autoSaveTimer?.Stop();
    }

    private async Task SaveRoom()
    {
        if (editModel is null)
            return;

        if (isSaving)
            return;

        if (string.IsNullOrWhiteSpace(editModel.Name))
        {
            lastError = L["rooms.nameRequired", "Room name is required"];
            return;
        }

        if (editModel.Capacity <= 0)
        {
            lastError = L["rooms.capacityRequired", "Capacity must be greater than 0"];
            return;
        }

        isSaving = true;
        lastError = null;
        lastWarning = null;
        hasUnsavedChanges = false;

        try
        {
            var roomDto = editModel.ToDto();
            HttpResponseMessage response;
            if (string.IsNullOrEmpty(editModel.Id))
            {
                // Create new
                response = await Http.PostAsJsonAsync("/api/rooms", roomDto);
            }
            else
            {
                // Update existing
                response = await Http.PutAsJsonAsync($"/api/rooms/{editModel.Id}", roomDto);
            }

            if (response.IsSuccessStatusCode)
            {
                var text = await response.Content.ReadAsStringAsync();
                var result = JsonSerializer.Deserialize<RoomDto>(text, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (result is not null)
                {
                    selectedRoom = result;
                    editModel = RoomEditModel.FromDto(result);
                    isSaved = true;
                    statusMessage = L["common.saved", "Saved"];
                    await LoadRooms();
                }
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
                {
                    lastWarning = L["rooms.exists", "Room already exists"];
                }
                else
                {
                    lastError = string.Format(L["rooms.saveFailedStatus", "Error saving room: {0}"], response.StatusCode);
                }
            }
        }
        catch (Exception ex)
        {
            lastError = string.Format(L["rooms.saveFailed", "Failed to save room: {0}"], ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DuplicateRoom()
    {
        if (editModel is null)
            return;

        editModel = new RoomEditModel
        {
            Id = null,
            Name = $"{editModel.Name}-copy",
            Capacity = editModel.Capacity,
            FloorNumber = editModel.FloorNumber,
            HouseNumber = editModel.HouseNumber,
            Priority = editModel.Priority,
            SecondaryPriority = editModel.SecondaryPriority,
            HasBeds = editModel.HasBeds,
            NeighboringRooms = editModel.NeighboringRooms,
            Comments = editModel.Comments
        };
        isSaved = false;
    }

    private async Task DeleteRoom()
    {
        if (editModel?.Id is null)
            return;

        if (!await ConfirmDelete())
            return;

        isSaving = true;
        try
        {
            var response = await Http.DeleteAsync($"/api/rooms/{editModel.Id}");
            if (response.IsSuccessStatusCode)
            {
                await LoadRooms();
                selectedRoom = null;
                editModel = null;
                isSaved = true;
                lastError = null;
            }
            else
            {
                lastError = string.Format(L["rooms.deleteFailedStatus", "Failed to delete room: {0}"], response.StatusCode);
            }
        }
        catch (Exception ex)
        {
            lastError = string.Format(L["rooms.deleteFailed", "Failed to delete room: {0}"], ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task<bool> ConfirmDelete()
    {
        return await JS.InvokeAsync<bool>("confirm", string.Format(L["rooms.deleteConfirm", "Are you sure you want to delete room {0}?"], editModel?.Name));
    }

    private static HashSet<string> ParseNeighborList(string? raw)
    {
        var result = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        if (string.IsNullOrWhiteSpace(raw))
            return result;

        foreach (var value in raw.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            if (!string.IsNullOrWhiteSpace(value))
                result.Add(value);
        }

        return result;
    }

    private sealed class NaturalRoomNameComparer : IComparer<string?>
    {
        public static NaturalRoomNameComparer Instance { get; } = new();

        public int Compare(string? left, string? right)
        {
            if (ReferenceEquals(left, right))
                return 0;

            if (left is null)
                return -1;

            if (right is null)
                return 1;

            var leftParts = Regex.Matches(left, "\\d+|\\D+").Select(match => match.Value).ToList();
            var rightParts = Regex.Matches(right, "\\d+|\\D+").Select(match => match.Value).ToList();
            var maxParts = Math.Max(leftParts.Count, rightParts.Count);

            for (var index = 0; index < maxParts; index++)
            {
                if (index >= leftParts.Count)
                    return -1;

                if (index >= rightParts.Count)
                    return 1;

                var leftPart = leftParts[index];
                var rightPart = rightParts[index];
                var leftIsNumber = long.TryParse(leftPart, out var leftNumber);
                var rightIsNumber = long.TryParse(rightPart, out var rightNumber);

                if (leftIsNumber && rightIsNumber)
                {
                    var numericCompare = leftNumber.CompareTo(rightNumber);
                    if (numericCompare != 0)
                        return numericCompare;

                    var lengthCompare = leftPart.Length.CompareTo(rightPart.Length);
                    if (lengthCompare != 0)
                        return lengthCompare;
                    continue;
                }

                var textCompare = StringComparer.OrdinalIgnoreCase.Compare(leftPart, rightPart);
                if (textCompare != 0)
                    return textCompare;
            }

            return StringComparer.OrdinalIgnoreCase.Compare(left, right);
        }
    }

    private static string? SerializeNeighborList(HashSet<string> neighbors)
    {
        if (neighbors.Count == 0)
            return null;

        return string.Join(",", neighbors.OrderBy(x => x, StringComparer.OrdinalIgnoreCase));
    }

    private static bool AreNeighbors(RoomDto left, RoomDto right)
    {
        if (string.IsNullOrWhiteSpace(left.Name) || string.IsNullOrWhiteSpace(right.Name))
            return false;

        var leftNeighbors = ParseNeighborList(left.NeighboringRooms);
        var rightNeighbors = ParseNeighborList(right.NeighboringRooms);
        return leftNeighbors.Contains(right.Name) || rightNeighbors.Contains(left.Name);
    }

    private async Task UpdateNeighborPair(RoomDto rowRoom, RoomDto colRoom, bool isChecked)
    {
        if (rooms is null)
            return;

        if (string.IsNullOrWhiteSpace(rowRoom.Id) || string.IsNullOrWhiteSpace(colRoom.Id))
            return;

        if (string.IsNullOrWhiteSpace(rowRoom.Name) || string.IsNullOrWhiteSpace(colRoom.Name))
            return;

        var rowNeighbors = ParseNeighborList(rowRoom.NeighboringRooms);
        var colNeighbors = ParseNeighborList(colRoom.NeighboringRooms);

        if (isChecked)
        {
            rowNeighbors.Add(colRoom.Name);
            colNeighbors.Add(rowRoom.Name);
        }
        else
        {
            rowNeighbors.Remove(colRoom.Name);
            colNeighbors.Remove(rowRoom.Name);
        }

        rowRoom = rowRoom with { NeighboringRooms = SerializeNeighborList(rowNeighbors) };
        colRoom = colRoom with { NeighboringRooms = SerializeNeighborList(colNeighbors) };

        var rowResponse = await Http.PutAsJsonAsync($"/api/rooms/{rowRoom.Id}", rowRoom);
        var colResponse = await Http.PutAsJsonAsync($"/api/rooms/{colRoom.Id}", colRoom);

        if (!rowResponse.IsSuccessStatusCode || !colResponse.IsSuccessStatusCode)
        {
            lastError = string.Format(L["rooms.saveFailedStatus", "Error saving room: {0}"],
                !rowResponse.IsSuccessStatusCode ? rowResponse.StatusCode : colResponse.StatusCode);
            return;
        }

        await LoadRooms();

        if (selectedRoom?.Id is not null && rooms is not null)
        {
            var refreshed = rooms.FirstOrDefault(r => string.Equals(r.Id, selectedRoom.Id, StringComparison.OrdinalIgnoreCase));
            if (refreshed is not null)
            {
                selectedRoom = refreshed;
                if (editModel?.Id is not null && string.Equals(editModel.Id, refreshed.Id, StringComparison.OrdinalIgnoreCase))
                {
                    editModel = RoomEditModel.FromDto(refreshed);
                }
            }
        }

        isSaved = true;
        statusMessage = L["common.saved", "Saved"];
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        autoSaveTimer?.Dispose();
    }
}


