@page "/sessions"
@using HotelDruid.Client.Services
@inject ISessionApiService SessionApi
@inject HttpClient Http

@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["sessions.title", "Sessions"]</PageTitle>

<div class="container-fluid">
    <div class="row">
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@L["sessions.title", "Sessions"]</h5>
                    <button class="btn btn-success btn-sm w-100 mb-2" @onclick="AddNew"><span class="bi bi-plus"></span> New Session</button>
                    @if (items == null)
                    {
                        <div>@L["common.loading", "Loading..."]</div>
                    }
                    else if (items.Count == 0)
                    {
                        <div class="alert alert-info">No active sessions.</div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var item in items)
                            {
                                <a class="list-group-item list-group-item-action @(selected?.SessionId == item.SessionId ? "active" : "")" @onclick="() => Select(item)">
                                    @item.SessionId (user @item.UserId)
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@L["sessions.title", "Sessions"]</h5>
                    @if (selected == null)
                    {
                        <div class="mb-3">
                            <label class="form-label">Session ID</label>
                            <input class="form-control" @bind="editSessionId" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">User ID</label>
                            <input class="form-control" type="number" @bind="editUserId" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">IP Address</label>
                            <input class="form-control" @bind="editIpAddress" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Connection Type</label>
                            <input class="form-control" @bind="editConnectionType" />
                        </div>
                        <button class="btn btn-primary" @onclick="Create">Create</button>
                    }
                    else
                    {
                        <div class="d-flex gap-2">
                            <button class="btn btn-warning" @onclick="Touch">Touch (Update Last Access)</button>
                            <button class="btn btn-danger" @onclick="Delete">@L["common.delete", "Delete"]</button>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@L["sessions.title", "Sessions"]</h5>
                    @if (selected != null)
                    {
                        <dl class="row">
                            <dt class="col-5">Session ID</dt><dd class="col-7">@selected.SessionId</dd>
                            <dt class="col-5">User ID</dt><dd class="col-7">@selected.UserId</dd>
                            <dt class="col-5">IP</dt><dd class="col-7">@selected.IpAddress</dd>
                            <dt class="col-5">Type</dt><dd class="col-7">@selected.ConnectionType</dd>
                            <dt class="col-5">Last Access</dt><dd class="col-7">@selected.LastAccess</dd>
                        </dl>
                    }
                    else
                    {
                        <div class="text-muted">Select a session to view details</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<SessionApiDto>? items;
    private SessionApiDto? selected;
    private string editSessionId = string.Empty;
    private int? editUserId;
    private string editIpAddress = string.Empty;
    private string editConnectionType = string.Empty;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        items = await SessionApi.GetSessionsAsync();
        StateHasChanged();
    }

    private void Select(SessionApiDto item)
    {
        selected = item;
    }

    private void AddNew()
    {
        selected = null;
        editSessionId = string.Empty;
        editUserId = null;
        editIpAddress = string.Empty;
        editConnectionType = string.Empty;
    }

    private async Task Create()
    {
        if (string.IsNullOrWhiteSpace(editSessionId) || !editUserId.HasValue) return;
        var dto = new SessionApiDto(editSessionId, editUserId, editIpAddress, editConnectionType, null);
        await SessionApi.CreateSessionAsync(dto);
        await Load();
    }

    private async Task Touch()
    {
        if (selected == null) return;
        var updated = await SessionApi.TouchSessionAsync(selected.SessionId!);
        if (updated != null) selected = updated;
        await Load();
    }

    private async Task Delete()
    {
        if (selected == null) return;
        await SessionApi.DeleteSessionAsync(selected.SessionId!);
        selected = null;
        await Load();
    }
}


