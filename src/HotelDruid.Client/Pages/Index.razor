@page "/"
@using System.Net.Http.Json
@using HotelDruid.Client.Shared
@using Microsoft.Extensions.Localization
@using HotelDruid.Client.Localization
@using HotelDruid.Client.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IActiveYearService ActiveYearService
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Index.PageTitle"]</PageTitle>

<div class="landing-hero py-5 bg-light">
  <div class="container">
    <div class="text-center mb-4">
      <h1 class="display-5">@L["Index.HeroTitle"]</h1>
      <p class="lead text-muted">@L["Index.HeroSubtitle"]</p>
    </div>

    <div class="row gx-3 gy-3 features">
      <div class="col-6 col-md-3">
        <FeatureCard Title="@L["Index.Feature.Rooms.Title"]" Subtitle="@L["Index.Feature.Rooms.Subtitle"]" ButtonText="@L["Index.Feature.Rooms.Button"]" ButtonLink="/rooms" BorderClass="border-success" Icon="bi-house-fill" />
      </div>
      <div class="col-6 col-md-3">
        <FeatureCard Title="@L["Index.Feature.Assets.Title"]" Subtitle="@L["Index.Feature.Assets.Subtitle"]" ButtonText="@L["Index.Feature.Assets.Button"]" ButtonLink="/assets" BorderClass="border-info" Icon="bi-box-seam" />
      </div>
      <div class="col-6 col-md-3">
        <FeatureCard Title="@L["Index.Feature.Warehouses.Title"]" Subtitle="@L["Index.Feature.Warehouses.Subtitle"]" ButtonText="@L["Index.Feature.Warehouses.Button"]" ButtonLink="/warehouses" BorderClass="border-secondary" Icon="bi-buildings" />
      </div>
      <div class="col-6 col-md-3">
        <FeatureCard Title="@L["Index.Feature.Inventory.Title"]" Subtitle="@L["Index.Feature.Inventory.Subtitle"]" ButtonText="@L["Index.Feature.Inventory.Button"]" ButtonLink="/inventory" BorderClass="border-dark" Icon="bi-boxes" />
      </div>
      <div class="col-6 col-md-3">
        <FeatureCard Title="@L["Index.Feature.Reservations.Title"]" Subtitle="@L["Index.Feature.Reservations.Subtitle"]" ButtonText="@L["Index.Feature.Reservations.Button"]" ButtonLink="/bookings" BorderClass="border-primary" Icon="bi-calendar-check-fill" />
      </div>
      <div class="col-6 col-md-3">
        <FeatureCard Title="@L["Index.Feature.Clients.Title"]" Subtitle="@L["Index.Feature.Clients.Subtitle"]" ButtonText="@L["Index.Feature.Clients.Button"]" ButtonLink="/clients" BorderClass="border-warning" Icon="bi-people-fill" />
      </div>
      <div class="col-6 col-md-3">
        <FeatureCard Title="@L["Index.Feature.Calendar.Title"]" Subtitle="@L["Index.Feature.Calendar.Subtitle"]" ButtonText="@L["Index.Feature.Calendar.Button"]" ButtonLink="/calendar" BorderClass="border-purple" Icon="bi-calendar2-week-fill" />
      </div>
    </div>

    <div class="quick-actions mt-4">
      <div class="d-flex gap-3 justify-content-center">
        <QuickAction Text="@L["Index.QuickAction.NewReservation"]" Icon="bi-plus" Link="/bookings/new" ColorClass="btn-success" />
        <QuickAction Text="@L["Index.QuickAction.AddRoom"]" Icon="bi-door-open" Link="/rooms/new" ColorClass="btn-primary" />
          <QuickAction Text="@L["Index.QuickAction.AddAsset"]" Icon="bi-box" Link="/assets" ColorClass="btn-info" />
        <QuickAction Text="@L["Index.QuickAction.NewClient"]" Icon="bi-person-plus" Link="/clients/new" ColorClass="btn-warning" />
        <QuickAction Text="@L["Index.QuickAction.Report"]" Icon="bi-bar-chart" Link="/reports" ColorClass="btn-purple" />
      </div>
    </div>

    <div class="status-row mt-5">
      <div class="row gx-3">
        <div class="col-6 col-md-3">
          <StatusTile Title="@L["Index.Status.ActiveYear"]" Value="@activeYearDisplay" />
        </div>
        <div class="col-6 col-md-3">
          <StatusTile Title="@L["Index.Status.Clients"]" Value="@(clients?.Count.ToString() ?? "0")" />
        </div>
        <div class="col-6 col-md-3">
          <StatusTile Title="@L["Index.Status.Bookings"]" Value="@(bookings?.Count.ToString() ?? "0")" />
        </div>
        <div class="col-6 col-md-3">
          <StatusTile Title="@L["Index.Status.Version"]" Value="@(status?.Version ?? "HotelDruid 3.0.7")" />
        </div>
      </div>
    </div>
  </div>
</div>

@code {

    private StatusDto? status;
    private List<ClientDto>? clients;
    private List<BookingDto>? bookings;
    private string activeYearDisplay = DateTime.Now.Year.ToString();

    protected override async Task OnInitializedAsync()
    {
        try
        {
          activeYearDisplay = ActiveYearService.CurrentYear.ToString();
          var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
          var setupQuery = uri.Query.Contains("configure=true", StringComparison.OrdinalIgnoreCase) ? "?configure=true" : string.Empty;
          var setup = await Http.GetFromJsonAsync<SetupStatusDto>($"/api/system/setup/status{setupQuery}");
          if (setup?.RequiresSetup == true)
          {
            Navigation.NavigateTo($"/setup?reason={setup.Reason}");
            return;
          }

          var statusTask = Http.GetFromJsonAsync<StatusDto>("/api/status");
          var clientsTask = Http.GetFromJsonAsync<List<ClientDto>>("/api/clients");
          var bookingsTask = Http.GetFromJsonAsync<List<BookingDto>>("/api/bookings");

          await Task.WhenAll(statusTask, clientsTask, bookingsTask);

          status = statusTask.Result;
          clients = clientsTask.Result;
          bookings = bookingsTask.Result;
        }
        catch
        {
          // API may not be running during early development — ignore
        }
    }

    private class StatusDto
    {
      public string? ActiveYear { get; set; }
      public string? User { get; set; }
      public string? Version { get; set; }
    }

    private class ClientDto
    {
      public int Id { get; set; }
      public string? Name { get; set; }
      public string? Email { get; set; }
      public string? Phone { get; set; }
    }

    private class BookingDto
    {
      public int Id { get; set; }
      public int ClientId { get; set; }
      public string? ArrivalDate { get; set; }
      public string? DepartureDate { get; set; }
      public string? Status { get; set; }
    }

    private class SetupStatusDto
    {
      public bool RequiresSetup { get; set; }
      public string? Reason { get; set; }
    }
}

