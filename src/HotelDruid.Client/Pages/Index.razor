@page "/"
@using System.Net.Http.Json
@using HotelDruid.Client.Shared
@inject HttpClient Http

<div class="landing-hero py-5 bg-light">
  <div class="container">
    <div class="text-center mb-4">
      <h1 class="display-5">Welcome to HotelDruid</h1>
      <p class="lead text-muted">Hotel Management Control Center</p>
    </div>

    <div class="row gx-3 gy-3 features">
      <div class="col-6 col-md-3">
        <FeatureCard Title="Rooms" Subtitle="Apartment management" ButtonText="Manage Rooms" ButtonLink="/rooms" BorderClass="border-success" Icon="bi-house-fill" />
      </div>
      <div class="col-6 col-md-3">
        <FeatureCard Title="Assets" Subtitle="Asset inventory" ButtonText="Manage Assets" ButtonLink="/assets" BorderClass="border-info" Icon="bi-box-seam" />
      </div>
      <div class="col-6 col-md-3">
        <FeatureCard Title="Warehouses" Subtitle="Stock locations" ButtonText="Manage Warehouses" ButtonLink="/warehouses" BorderClass="border-secondary" Icon="bi-buildings" />
      </div>
      <div class="col-6 col-md-3">
        <FeatureCard Title="Inventory" Subtitle="Inventory items" ButtonText="Manage Inventory" ButtonLink="/inventory" BorderClass="border-dark" Icon="bi-boxes" />
      </div>
      <div class="col-6 col-md-3">
        <FeatureCard Title="Reservations" Subtitle="Reservation management" ButtonText="View Reservations" ButtonLink="/bookings" BorderClass="border-primary" Icon="bi-calendar-check-fill" />
      </div>
      <div class="col-6 col-md-3">
        <FeatureCard Title="Clients" Subtitle="Guest management" ButtonText="Manage Clients" ButtonLink="/clients" BorderClass="border-warning" Icon="bi-people-fill" />
      </div>
      <div class="col-6 col-md-3">
        <FeatureCard Title="Calendar" Subtitle="Calendar view" ButtonText="View Calendar" ButtonLink="/calendar" BorderClass="border-purple" Icon="bi-calendar2-week-fill" />
      </div>
    </div>

    <div class="quick-actions mt-4">
      <div class="d-flex gap-3 justify-content-center">
        <QuickAction Text="New Reservation" Icon="bi-plus" Link="/bookings/new" ColorClass="btn-success" />
        <QuickAction Text="Add Room" Icon="bi-door-open" Link="/rooms/new" ColorClass="btn-primary" />
          <QuickAction Text="Add Asset" Icon="bi-box" Link="/assets" ColorClass="btn-info" />
        <QuickAction Text="New Client" Icon="bi-person-plus" Link="/clients/new" ColorClass="btn-warning" />
        <QuickAction Text="Report" Icon="bi-bar-chart" Link="/reports" ColorClass="btn-purple" />
      </div>
    </div>

    <div class="status-row mt-5">
      <div class="row gx-3">
        <div class="col-6 col-md-3">
          <StatusTile Title="Active Year" Value="@(status?.ActiveYear ?? "2026")" />
        </div>
        <div class="col-6 col-md-3">
          <StatusTile Title="Clients" Value="@(clients?.Count.ToString() ?? "0")" />
        </div>
        <div class="col-6 col-md-3">
          <StatusTile Title="Bookings" Value="@(bookings?.Count.ToString() ?? "0")" />
        </div>
        <div class="col-6 col-md-3">
          <StatusTile Title="Version" Value="@(status?.Version ?? "HotelDruid 3.0.7")" />
        </div>
      </div>
    </div>
  </div>
</div>

@code {

    private StatusDto? status;
    private List<ClientDto>? clients;
    private List<BookingDto>? bookings;

    protected override async Task OnInitializedAsync()
    {
        try
        {
          var statusTask = Http.GetFromJsonAsync<StatusDto>("/api/status");
          var clientsTask = Http.GetFromJsonAsync<List<ClientDto>>("/api/clients");
          var bookingsTask = Http.GetFromJsonAsync<List<BookingDto>>("/api/bookings");

          await Task.WhenAll(statusTask, clientsTask, bookingsTask);

          status = statusTask.Result;
          clients = clientsTask.Result;
          bookings = bookingsTask.Result;
        }
        catch
        {
          // API may not be running during early development — ignore
        }
    }

    private class StatusDto
    {
      public string? ActiveYear { get; set; }
      public string? User { get; set; }
      public string? Version { get; set; }
    }

    private class ClientDto
    {
      public int Id { get; set; }
      public string? Name { get; set; }
      public string? Email { get; set; }
      public string? Phone { get; set; }
    }

    private class BookingDto
    {
      public int Id { get; set; }
      public int ClientId { get; set; }
      public string? ArrivalDate { get; set; }
      public string? DepartureDate { get; set; }
      public string? Status { get; set; }
    }
}

