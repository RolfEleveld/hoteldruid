@page "/family-relationships"
@using HotelDruid.Client.Services
@inject IFamilyRelationshipApiService FamilyRelationshipApi

@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["familyRelationships.title", "Family Relationships"]</PageTitle>

<div class="container-fluid assets-manager">
    <div class="row">
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@L["familyRelationships.title", "Family Relationships"]</h5>
                    <button class="btn btn-success btn-sm w-100 mb-2" @onclick="AddNew"><span class="bi bi-plus"></span> Add Relationship</button>
                    @if (items == null)
                    {
                        <div>@L["common.loading", "Loading..."]</div>
                    }
                    else if (items.Count == 0)
                    {
                        <div class="alert alert-info">@L["familyRelationships.emptyList", "No relationship types defined."]</div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var item in items)
                            {
                                <a class="list-group-item list-group-item-action @(selected?.Id == item.Id ? "active" : "")" @onclick="() => Select(item)">@item.Name</a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@L["familyRelationships.title", "Family Relationships"]</h5>
                    <div class="mb-3">
                        <label class="form-label">Relationship <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="editModel.Name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Code</label>
                        <input class="form-control" @bind="editModel.Code" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Code 2</label>
                        <input class="form-control" @bind="editModel.Code2" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Code 3</label>
                        <input class="form-control" @bind="editModel.Code3" />
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" @onclick="Save">@L["common.save", "Save"]</button>
                        @if (selected != null)
                        {
                            <button class="btn btn-danger" @onclick="Delete">@L["common.delete", "Delete"]</button>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger mt-2">@errorMessage</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@L["familyRelationships.title", "Family Relationships"]</h5>
                    @if (selected != null)
                    {
                        <dl class="row">
                            <dt class="col-4">ID</dt><dd class="col-8">@selected.Id</dd>
                            <dt class="col-4">Created</dt><dd class="col-8">@selected.CreatedAt</dd>
                            <dt class="col-4">Code</dt><dd class="col-8">@selected.Code</dd>
                            <dt class="col-4">Code 2</dt><dd class="col-8">@selected.Code2</dd>
                            <dt class="col-4">Code 3</dt><dd class="col-8">@selected.Code3</dd>
                        </dl>
                    }
                    else
                    {
                        <div class="text-muted">Select a relationship to view details</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<FamilyRelationshipDto>? items;
    private FamilyRelationshipDto? selected;
    private EditModel editModel = new();
    private string? errorMessage;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        items = await FamilyRelationshipApi.GetAllAsync();
        StateHasChanged();
    }

    private void Select(FamilyRelationshipDto item)
    {
        selected = item;
        editModel = EditModel.From(item);
        errorMessage = null;
    }

    private void AddNew()
    {
        selected = null;
        editModel = new EditModel();
        errorMessage = null;
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(editModel.Name)) { errorMessage = "Name is required."; return; }
        errorMessage = null;
        var dto = editModel.ToDto();
        try
        {
            if (selected == null) await FamilyRelationshipApi.CreateAsync(dto);
            else await FamilyRelationshipApi.UpdateAsync(selected.Id, dto);
            await Load();
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task Delete()
    {
        if (selected == null) return;
        await FamilyRelationshipApi.DeleteAsync(selected.Id);
        selected = null;
        await Load();
    }

    private class EditModel
    {
        public string Name { get; set; } = string.Empty;
        public string? Code { get; set; }
        public string? Code2 { get; set; }
        public string? Code3 { get; set; }

        public FamilyRelationshipDto ToDto() => new(Id: string.Empty, Name: Name, Code: Code, Code2: Code2, Code3: Code3, CreatedAt: null);
        public static EditModel From(FamilyRelationshipDto dto) => new() { Name = dto.Name ?? string.Empty, Code = dto.Code, Code2 = dto.Code2, Code3 = dto.Code3 };
    }
}


