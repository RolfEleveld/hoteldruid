@page "/years"
@using HotelDruid.Client.Services
@inject IYearApiService YearApi

<PageTitle>Years</PageTitle>
<div class="container-fluid">
    <div class="row">
        <div class="col-md-3 border-end">
            <h5 class="mt-3">Years</h5>
            <button class="btn btn-sm btn-primary mb-2" @onclick="NewRecord">+ New</button>
            @if (records is null) { <p><em>Loading...</em></p> }
            else if (records.Count == 0) { <p class="text-muted">No years defined</p> }
            else
            {
                <ul class="list-group">
                    @foreach (var r in records)
                    {
                        <li class="list-group-item list-group-item-action @(selected?.Year == r.Year ? "active" : "")"
                            style="cursor:pointer" @onclick="() => SelectRecord(r)">
                            <div class="fw-bold">@r.Year</div>
                            <small>@r.PeriodType</small>
                        </li>
                    }
                </ul>
            }
        </div>
        <div class="col-md-6 border-end">
            @if (editing)
            {
                <h5 class="mt-3">@(isNew ? "New Year" : "Edit Year")</h5>
                <div class="row g-2">
                    <div class="col-6"><label>Year *</label><input class="form-control" type="number" @bind="form.Year" /></div>
                    <div class="col-6"><label>Period Type</label><input class="form-control" @bind="form.PeriodType" placeholder="variable" /></div>
                </div>
                @if (!string.IsNullOrEmpty(errorMsg)) { <div class="alert alert-danger mt-2">@errorMsg</div> }
                <div class="mt-3">
                    <button class="btn btn-primary me-2" @onclick="Save">Save</button>
                    <button class="btn btn-secondary" @onclick="Cancel">Cancel</button>
                </div>
            }
        </div>
        <div class="col-md-3">
            @if (selected is not null && !editing)
            {
                <h5 class="mt-3">Details</h5>
                <dl>
                    <dt>Year</dt><dd>@selected.Year</dd>
                    <dt>Period Type</dt><dd>@selected.PeriodType</dd>
                </dl>
                <button class="btn btn-sm btn-outline-primary me-1" @onclick="EditSelected">Edit</button>
                <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelected">Delete</button>
            }
        </div>
    </div>
</div>

@code {
    private List<YearDto>? records;
    private YearDto? selected;
    private bool editing, isNew;
    private string errorMsg = "";
    private FormModel form = new();

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task LoadAll() => records = await YearApi.ListAsync();

    private void NewRecord() { form = new(); isNew = true; editing = true; selected = null; errorMsg = ""; }
    private void SelectRecord(YearDto r) { selected = r; editing = false; }
    private void EditSelected()
    {
        if (selected is null) return;
        form = new() { Year = selected.Year, PeriodType = selected.PeriodType };
        isNew = false; editing = true; errorMsg = "";
    }

    private async Task Save()
    {
        if (form.Year == 0) { errorMsg = "Year is required."; return; }
        var dto = new YearDto(form.Year, form.PeriodType);
        try
        {
            if (isNew) await YearApi.CreateAsync(dto);
            else await YearApi.UpdateAsync(selected!.Year, dto);
            editing = false;
            await LoadAll();
        }
        catch { errorMsg = "Save failed."; }
    }

    private void Cancel() { editing = false; errorMsg = ""; }

    private async Task DeleteSelected()
    {
        if (selected is null) return;
        try { await YearApi.DeleteAsync(selected.Year); selected = null; await LoadAll(); }
        catch { errorMsg = "Delete failed."; }
    }

    private class FormModel
    {
        public int Year { get; set; }
        public string? PeriodType { get; set; }
    }
}

