@page "/assignment-rules"
@using HotelDruid.Client.Services
@inject IAssignmentRuleApiService AssignmentRuleApi

@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["assignmentRules.title", "Assignment Rules"]</PageTitle>
<div class="container-fluid">
    <div class="row align-items-center mb-2 mt-2">
        <div class="col-auto"><h5 class="mb-0">Assignment Rules</h5></div>
        <div class="col-auto">
            <label class="me-1">Year:</label>
            <input class="form-control d-inline-block" type="number" @bind="filterYear" style="width:90px" />
            <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="ApplyFilter">Load</button>
        </div>
    </div>
    <div class="row">
        <div class="col-md-3 border-end">
            <button class="btn btn-sm btn-primary mb-2" @onclick="NewRecord">+ New</button>
            @if (records is null) { <p><em>@L["common.loading", "Loading..."]</em></p> }
            else if (records.Count == 0) { <p class="text-muted">No assignment rules</p> }
            else
            {
                <ul class="list-group">
                    @foreach (var r in records)
                    {
                        <li class="list-group-item list-group-item-action @(selected?.Id == r.Id ? "active" : "")"
                            style="cursor:pointer" @onclick="() => SelectRecord(r)">
                            <div class="fw-bold">@r.Year — @r.RoomOrAgency</div>
                            <small>@r.ClosedTariff</small>
                        </li>
                    }
                </ul>
            }
        </div>
        <div class="col-md-6 border-end">
            @if (editing)
            {
                <h5 class="mt-1">@(isNew ? "New Assignment Rule" : "Edit Assignment Rule")</h5>
                <div class="row g-2">
                    <div class="col-6"><label>Year *</label><input class="form-control" type="number" @bind="form.Year" /></div>
                    <div class="col-6"><label>Room or Agency</label><input class="form-control" @bind="form.RoomOrAgency" /></div>
                    <div class="col-6"><label>Closed Tariff</label><input class="form-control" @bind="form.ClosedTariff" /></div>
                    <div class="col-6"><label>Tariff Per Room</label><input class="form-control" @bind="form.TariffPerRoom" /></div>
                    <div class="col-6"><label>Start Period ID</label><input class="form-control" type="number" @bind="form.StartPeriodId" /></div>
                    <div class="col-6"><label>End Period ID</label><input class="form-control" type="number" @bind="form.EndPeriodId" /></div>
                    <div class="col-12"><label>Reason</label><input class="form-control" @bind="form.Reason1" /></div>
                </div>
                @if (!string.IsNullOrEmpty(errorMsg)) { <div class="alert alert-danger mt-2">@errorMsg</div> }
                <div class="mt-3">
                    <button class="btn btn-primary me-2" @onclick="Save">@L["common.save", "Save"]</button>
                    <button class="btn btn-secondary" @onclick="Cancel">@L["common.cancel", "Cancel"]</button>
                </div>
            }
        </div>
        <div class="col-md-3">
            @if (selected is not null && !editing)
            {
                <h5 class="mt-1">@L["common.details", "Details"]</h5>
                <dl>
                    <dt>Year</dt><dd>@selected.Year</dd>
                    <dt>Room / Agency</dt><dd>@selected.RoomOrAgency</dd>
                    <dt>Closed Tariff</dt><dd>@selected.ClosedTariff</dd>
                    <dt>Tariff Per Room</dt><dd>@selected.TariffPerRoom</dd>
                    <dt>Start Period</dt><dd>@selected.StartPeriodId</dd>
                    <dt>End Period</dt><dd>@selected.EndPeriodId</dd>
                    <dt>Reason</dt><dd>@selected.Reason1</dd>
                </dl>
                <button class="btn btn-sm btn-outline-primary me-1" @onclick="EditSelected">Edit</button>
                <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelected">@L["common.delete", "Delete"]</button>
            }
        </div>
    </div>
</div>

@code {
    private List<AssignmentRuleDto>? records;
    private AssignmentRuleDto? selected;
    private bool editing, isNew;
    private string errorMsg = "";
    private int? filterYear;
    private FormModel form = new();

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task LoadAll() => records = await AssignmentRuleApi.ListAsync(filterYear);
    private async Task ApplyFilter() => await LoadAll();

    private void NewRecord() { form = new() { Year = filterYear ?? DateTime.Now.Year }; isNew = true; editing = true; selected = null; errorMsg = ""; }
    private void SelectRecord(AssignmentRuleDto r) { selected = r; editing = false; }
    private void EditSelected()
    {
        if (selected is null) return;
        form = new() { Year = selected.Year, RoomOrAgency = selected.RoomOrAgency, ClosedTariff = selected.ClosedTariff, TariffPerRoom = selected.TariffPerRoom, StartPeriodId = selected.StartPeriodId, EndPeriodId = selected.EndPeriodId, Reason1 = selected.Reason1 };
        isNew = false; editing = true; errorMsg = "";
    }

    private async Task Save()
    {
        if (form.Year == 0) { errorMsg = "Year is required."; return; }
        var dto = new AssignmentRuleDto(selected?.Id, form.Year, form.RoomOrAgency, form.ClosedTariff, form.TariffPerRoom, form.StartPeriodId, form.EndPeriodId, form.Reason1);
        try
        {
            if (isNew) await AssignmentRuleApi.CreateAsync(dto);
            else await AssignmentRuleApi.UpdateAsync(selected!.Year, selected.Id!, dto);
            editing = false;
            await LoadAll();
        }
        catch { errorMsg = "Save failed."; }
    }

    private void Cancel() { editing = false; errorMsg = ""; }

    private async Task DeleteSelected()
    {
        if (selected?.Id is null) return;
        try { await AssignmentRuleApi.DeleteAsync(selected.Year, selected.Id); selected = null; await LoadAll(); }
        catch { errorMsg = "Delete failed."; }
    }

    private class FormModel
    {
        public int Year { get; set; }
        public string? RoomOrAgency { get; set; }
        public string? ClosedTariff { get; set; }
        public string? TariffPerRoom { get; set; }
        public int? StartPeriodId { get; set; }
        public int? EndPeriodId { get; set; }
        public string? Reason1 { get; set; }
    }
}


