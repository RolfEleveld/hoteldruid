@page "/cash-registers"
@using HotelDruid.Client.Services
@inject ICashRegisterApiService CashRegisterApi

<PageTitle>Cash Registers</PageTitle>

<div class="container-fluid assets-manager">
    <div class="row">
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Cash Registers</h5>
                    <button class="btn btn-success btn-sm w-100 mb-2" @onclick="AddNew"><span class="bi bi-plus"></span> Add Register</button>
                    @if (items == null)
                    {
                        <div>Loading...</div>
                    }
                    else if (items.Count == 0)
                    {
                        <div class="alert alert-info">No cash registers defined.</div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var item in items)
                            {
                                <a class="list-group-item list-group-item-action @(selected?.Id == item.Id ? "active" : "")" @onclick="() => Select(item)">
                                    @item.Name <span class="badge @(item.Status == "open" ? "bg-success" : "bg-secondary") ms-1">@item.Status</span>
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@((selected == null) ? "New Cash Register" : "Edit Cash Register")</h5>
                    <div class="mb-3">
                        <label class="form-label">Register Name <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="editModel.Name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Code</label>
                        <input class="form-control" @bind="editModel.Code" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <select class="form-select" @bind="editModel.Status">
                            <option value="open">Open</option>
                            <option value="closed">Closed</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" @bind="editModel.Description"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" @onclick="Save">Save</button>
                        @if (selected != null)
                        {
                            <button class="btn btn-danger" @onclick="Delete">Delete</button>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger mt-2">@errorMessage</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Details</h5>
                    @if (selected != null)
                    {
                        <dl class="row">
                            <dt class="col-5">ID</dt><dd class="col-7">@selected.Id</dd>
                            <dt class="col-5">Name</dt><dd class="col-7">@selected.Name</dd>
                            <dt class="col-5">Code</dt><dd class="col-7">@selected.Code</dd>
                            <dt class="col-5">Status</dt><dd class="col-7">@selected.Status</dd>
                            <dt class="col-5">Created</dt><dd class="col-7">@selected.CreatedAt</dd>
                        </dl>
                    }
                    else
                    {
                        <div class="text-muted">Select a register to view details</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<CashRegisterDto>? items;
    private CashRegisterDto? selected;
    private EditModel editModel = new();
    private string? errorMessage;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        items = await CashRegisterApi.GetAllAsync();
        StateHasChanged();
    }

    private void Select(CashRegisterDto item)
    {
        selected = item;
        editModel = EditModel.From(item);
        errorMessage = null;
    }

    private void AddNew()
    {
        selected = null;
        editModel = new EditModel();
        errorMessage = null;
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(editModel.Name)) { errorMessage = "Name is required."; return; }
        errorMessage = null;
        var dto = editModel.ToDto();
        try
        {
            if (selected == null) await CashRegisterApi.CreateAsync(dto);
            else await CashRegisterApi.UpdateAsync(selected.Id, dto);
            await Load();
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task Delete()
    {
        if (selected == null) return;
        await CashRegisterApi.DeleteAsync(selected.Id);
        selected = null;
        await Load();
    }

    private class EditModel
    {
        public string Name { get; set; } = string.Empty;
        public string? Code { get; set; }
        public string Status { get; set; } = "open";
        public string? Description { get; set; }

        public CashRegisterDto ToDto() => new(Id: string.Empty, Name: Name, Status: Status, Code: Code, Description: Description, CreatedAt: null);
        public static EditModel From(CashRegisterDto dto) => new() { Name = dto.Name ?? string.Empty, Code = dto.Code, Status = dto.Status ?? "open", Description = dto.Description };
    }
}

