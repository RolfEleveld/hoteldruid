@page "/booking-costs"
@using HotelDruid.Client.Services
@inject IBookingCostApiService BookingCostApi

@inject ILanguageService LanguageService

<PageTitle>@LanguageService.GetText("bookingCosts.title", "Booking Costs")</PageTitle>
<div class="container-fluid">
    <div class="row align-items-center mb-2 mt-2">
        <div class="col-auto"><h5 class="mb-0">Booking Costs</h5></div>
        <div class="col-auto">
            <label class="me-1">Year:</label>
            <input class="form-control d-inline-block" type="number" @bind="filterYear" style="width:90px" />
            <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="ApplyFilter">Load</button>
        </div>
    </div>
    <div class="row">
        <div class="col-md-3 border-end">
            <button class="btn btn-sm btn-primary mb-2" @onclick="NewRecord">+ New</button>
            @if (records is null) { <p><em>@LanguageService.GetText("common.loading", "Loading...")</em></p> }
            else if (records.Count == 0) { <p class="text-muted">No booking costs</p> }
            else
            {
                <ul class="list-group">
                    @foreach (var r in records)
                    {
                        <li class="list-group-item list-group-item-action @(selected?.Id == r.Id ? "active" : "")"
                            style="cursor:pointer" @onclick="() => SelectRecord(r)">
                            <div class="fw-bold">@r.Year — @r.BookingId</div>
                            <small>@r.Description (@r.Amount)</small>
                        </li>
                    }
                </ul>
            }
        </div>
        <div class="col-md-6 border-end">
            @if (editing)
            {
                <h5 class="mt-1">@(isNew ? "New Booking Cost" : "Edit Booking Cost")</h5>
                <div class="row g-2">
                    <div class="col-6"><label>Year *</label><input class="form-control" type="number" @bind="form.Year" /></div>
                    <div class="col-6"><label>Booking ID</label><input class="form-control" @bind="form.BookingId" /></div>
                    <div class="col-6"><label>Tariff ID</label><input class="form-control" @bind="form.TariffId" /></div>
                    <div class="col-6"><label>Amount</label><input class="form-control" type="number" @bind="form.Amount" /></div>
                    <div class="col-12"><label>Description</label><input class="form-control" @bind="form.Description" /></div>
                </div>
                @if (!string.IsNullOrEmpty(errorMsg)) { <div class="alert alert-danger mt-2">@errorMsg</div> }
                <div class="mt-3">
                    <button class="btn btn-primary me-2" @onclick="Save">@LanguageService.GetText("common.save", "Save")</button>
                    <button class="btn btn-secondary" @onclick="Cancel">@LanguageService.GetText("common.cancel", "Cancel")</button>
                </div>
            }
        </div>
        <div class="col-md-3">
            @if (selected is not null && !editing)
            {
                <h5 class="mt-1">@LanguageService.GetText("common.details", "Details")</h5>
                <dl>
                    <dt>Year</dt><dd>@selected.Year</dd>
                    <dt>Booking ID</dt><dd>@selected.BookingId</dd>
                    <dt>Tariff ID</dt><dd>@selected.TariffId</dd>
                    <dt>Amount</dt><dd>@selected.Amount</dd>
                    <dt>Description</dt><dd>@selected.Description</dd>
                </dl>
                <button class="btn btn-sm btn-outline-primary me-1" @onclick="EditSelected">Edit</button>
                <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelected">@LanguageService.GetText("common.delete", "Delete")</button>
            }
        </div>
    </div>
</div>

@code {
    private List<BookingCostClientDto>? records;
    private BookingCostClientDto? selected;
    private bool editing, isNew;
    private string errorMsg = "";
    private int? filterYear;
    private FormModel form = new();

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task LoadAll() => records = await BookingCostApi.ListAsync(filterYear);
    private async Task ApplyFilter() => await LoadAll();

    private void NewRecord() { form = new() { Year = filterYear ?? DateTime.Now.Year }; isNew = true; editing = true; selected = null; errorMsg = ""; }
    private void SelectRecord(BookingCostClientDto r) { selected = r; editing = false; }
    private void EditSelected()
    {
        if (selected is null) return;
        form = new() { Year = selected.Year, BookingId = selected.BookingId, TariffId = selected.TariffId, Amount = selected.Amount, Description = selected.Description };
        isNew = false; editing = true; errorMsg = "";
    }

    private async Task Save()
    {
        if (form.Year == 0) { errorMsg = "Year is required."; return; }
        var dto = new BookingCostClientDto(selected?.Id, form.Year, form.BookingId, form.TariffId, form.Amount, form.Description);
        try
        {
            if (isNew) await BookingCostApi.CreateAsync(dto);
            else await BookingCostApi.UpdateAsync(selected!.Year, selected.Id!, dto);
            editing = false;
            await LoadAll();
        }
        catch { errorMsg = "Save failed."; }
    }

    private void Cancel() { editing = false; errorMsg = ""; }

    private async Task DeleteSelected()
    {
        if (selected?.Id is null) return;
        try { await BookingCostApi.DeleteAsync(selected.Year, selected.Id); selected = null; await LoadAll(); }
        catch { errorMsg = "Delete failed."; }
    }

    private class FormModel
    {
        public int Year { get; set; }
        public string? BookingId { get; set; }
        public string? TariffId { get; set; }
        public double? Amount { get; set; }
        public string? Description { get; set; }
    }
}

