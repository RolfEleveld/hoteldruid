@page "/group-memberships"
@using HotelDruid.Client.Services
@inject IGroupMembershipApiService GroupMembershipApi

@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["groupMemberships.title", "Group Memberships"]</PageTitle>
<div class="container-fluid">
    <div class="row">
        <div class="col-md-4 border-end">
            <h5 class="mt-3">Group Memberships</h5>
            <div class="input-group mb-2">
                <input class="form-control" type="number" @bind="filterUserId" placeholder="Filter by User ID" />
                <button class="btn btn-outline-secondary" @onclick="LoadByUser">Filter</button>
            </div>
            <button class="btn btn-sm btn-primary mb-2" @onclick="NewRecord">+ New</button>
            @if (records is null) { <p><em>Load memberships by user ID above</em></p> }
            else if (records.Count == 0) { <p class="text-muted">No group memberships</p> }
            else
            {
                <ul class="list-group">
                    @foreach (var r in records)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>User @r.UserId → Group @r.GroupId</span>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteMembership(r)">×</button>
                        </li>
                    }
                </ul>
            }
        </div>
        <div class="col-md-5">
            @if (editing)
            {
                <h5 class="mt-3">New Membership</h5>
                <div class="mb-2"><label>User ID *</label><input class="form-control" type="number" @bind="form.UserId" /></div>
                <div class="mb-2"><label>Group ID *</label><input class="form-control" type="number" @bind="form.GroupId" /></div>
                @if (!string.IsNullOrEmpty(errorMsg)) { <div class="alert alert-danger">@errorMsg</div> }
                <button class="btn btn-primary me-2" @onclick="Save">@L["common.save", "Save"]</button>
                <button class="btn btn-secondary" @onclick="Cancel">@L["common.cancel", "Cancel"]</button>
            }
        </div>
    </div>
</div>

@code {
    private List<GroupMembershipDto>? records;
    private bool editing;
    private string errorMsg = "";
    private int? filterUserId;
    private FormModel form = new();

    private async Task LoadByUser()
    {
        if (filterUserId is null) return;
        records = await GroupMembershipApi.GetByUserAsync(filterUserId.Value);
    }

    private void NewRecord() { form = new(); editing = true; errorMsg = ""; }
    private void Cancel() { editing = false; errorMsg = ""; }

    private async Task Save()
    {
        if (form.UserId is null || form.GroupId is null) { errorMsg = "User ID and Group ID are required."; return; }
        var dto = new GroupMembershipDto(null, form.UserId, form.GroupId);
        try
        {
            await GroupMembershipApi.CreateAsync(dto);
            editing = false;
            if (filterUserId.HasValue) records = await GroupMembershipApi.GetByUserAsync(filterUserId.Value);
        }
        catch { errorMsg = "Save failed."; }
    }

    private async Task DeleteMembership(GroupMembershipDto r)
    {
        if (r.UserId is null || r.GroupId is null) return;
        try { await GroupMembershipApi.DeleteAsync(r.UserId.Value, r.GroupId.Value); if (filterUserId.HasValue) records = await GroupMembershipApi.GetByUserAsync(filterUserId.Value); }
        catch { errorMsg = "Delete failed."; }
    }

    private class FormModel
    {
        public int? UserId { get; set; }
        public int? GroupId { get; set; }
    }
}


