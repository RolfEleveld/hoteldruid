@page "/client-data"
@using HotelDruid.Client.Services
@inject IClientDataApiService ClientDataApi

<PageTitle>Client Data</PageTitle>
<div class="container-fluid">
    <div class="row">
        <div class="col-md-4 border-end">
            <h5 class="mt-3">Client Data</h5>
            <div class="mb-2">
                <input class="form-control" placeholder="Filter by Client ID" @bind="filterClientId" @bind:event="oninput" />
            </div>
            <button class="btn btn-sm btn-primary mb-2" @onclick="NewRecord">+ New</button>
            @if (records is null) { <p><em>Loading...</em></p> }
            else if (records.Count == 0) { <p class="text-muted">No client data records</p> }
            else
            {
                <ul class="list-group">
                    @foreach (var r in FilteredRecords)
                    {
                        <li class="list-group-item list-group-item-action @(selected?.Id == r.Id ? "active" : "")"
                            style="cursor:pointer" @onclick="() => SelectRecord(r)">
                            <div class="fw-bold">@r.ClientId — @r.Type</div>
                            <small>@r.Text1</small>
                        </li>
                    }
                </ul>
            }
        </div>
        <div class="col-md-5 border-end">
            @if (editing)
            {
                <h5 class="mt-3">@(isNew ? "New Record" : "Edit Record")</h5>
                <div class="mb-2"><label>Client ID *</label><input class="form-control" @bind="form.ClientId" /></div>
                <div class="mb-2"><label>Number</label><input class="form-control" type="number" @bind="form.Number" /></div>
                <div class="mb-2"><label>Type</label><input class="form-control" @bind="form.Type" /></div>
                <div class="mb-2"><label>Text 1</label><input class="form-control" @bind="form.Text1" /></div>
                <div class="mb-2"><label>Text 2</label><input class="form-control" @bind="form.Text2" /></div>
                <div class="mb-2"><label>Text 3</label><input class="form-control" @bind="form.Text3" /></div>
                <div class="mb-2"><label>Text 4</label><input class="form-control" @bind="form.Text4" /></div>
                <div class="mb-2"><label>Text 5</label><input class="form-control" @bind="form.Text5" /></div>
                <div class="mb-2"><label>Text 6</label><input class="form-control" @bind="form.Text6" /></div>
                <div class="mb-2"><label>Text 7</label><input class="form-control" @bind="form.Text7" /></div>
                <div class="mb-2"><label>Text 8</label><input class="form-control" @bind="form.Text8" /></div>
                @if (!string.IsNullOrEmpty(errorMsg)) { <div class="alert alert-danger">@errorMsg</div> }
                <button class="btn btn-primary me-2" @onclick="Save">Save</button>
                <button class="btn btn-secondary" @onclick="Cancel">Cancel</button>
            }
        </div>
        <div class="col-md-3">
            @if (selected is not null && !editing)
            {
                <h5 class="mt-3">Details</h5>
                <dl>
                    <dt>Client ID</dt><dd>@selected.ClientId</dd>
                    <dt>Number</dt><dd>@selected.Number</dd>
                    <dt>Type</dt><dd>@selected.Type</dd>
                    <dt>Text 1</dt><dd>@selected.Text1</dd>
                </dl>
                <button class="btn btn-sm btn-outline-primary me-1" @onclick="EditSelected">Edit</button>
                <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelected">Delete</button>
            }
        </div>
    </div>
</div>

@code {
    private List<ClientDataDto>? records;
    private ClientDataDto? selected;
    private bool editing, isNew;
    private string errorMsg = "";
    private string filterClientId = "";
    private FormModel form = new();

    private IEnumerable<ClientDataDto> FilteredRecords => string.IsNullOrEmpty(filterClientId)
        ? (records ?? new())
        : (records ?? new()).Where(r => r.ClientId?.Contains(filterClientId, StringComparison.OrdinalIgnoreCase) == true);

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task LoadAll()
    {
        var all = await ClientDataApi.GetByClientAsync("");
        // GetByClientAsync with empty string — fallback: load by getting all
        records = all;
    }

    private void NewRecord() { form = new(); isNew = true; editing = true; selected = null; errorMsg = ""; }
    private void SelectRecord(ClientDataDto r) { selected = r; editing = false; }
    private void EditSelected()
    {
        if (selected is null) return;
        form = new() { ClientId = selected.ClientId, Number = selected.Number, Type = selected.Type, Text1 = selected.Text1, Text2 = selected.Text2, Text3 = selected.Text3, Text4 = selected.Text4, Text5 = selected.Text5, Text6 = selected.Text6, Text7 = selected.Text7, Text8 = selected.Text8 };
        isNew = false; editing = true; errorMsg = "";
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(form.ClientId)) { errorMsg = "Client ID is required."; return; }
        var dto = new ClientDataDto(selected?.Id, form.ClientId, form.Number, form.Type, form.Text1, form.Text2, form.Text3, form.Text4, form.Text5, form.Text6, form.Text7, form.Text8);
        try
        {
            if (isNew) await ClientDataApi.CreateAsync(dto);
            else await ClientDataApi.UpdateAsync(selected!.Id!, dto);
            editing = false;
            await LoadAll();
        }
        catch { errorMsg = "Save failed."; }
    }

    private void Cancel() { editing = false; errorMsg = ""; }

    private async Task DeleteSelected()
    {
        if (selected?.Id is null) return;
        try { await ClientDataApi.DeleteAsync(selected.Id); selected = null; await LoadAll(); }
        catch { errorMsg = "Delete failed."; }
    }

    private class FormModel
    {
        public string? ClientId { get; set; }
        public int? Number { get; set; }
        public string? Type { get; set; }
        public string? Text1 { get; set; }
        public string? Text2 { get; set; }
        public string? Text3 { get; set; }
        public string? Text4 { get; set; }
        public string? Text5 { get; set; }
        public string? Text6 { get; set; }
        public string? Text7 { get; set; }
        public string? Text8 { get; set; }
    }
}

