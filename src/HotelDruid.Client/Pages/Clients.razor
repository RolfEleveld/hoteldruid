@page "/clients"
@using HotelDruid.Client.Services
@inject IClientApiService ClientApi

@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["clients.title", "Clients"]</PageTitle>
<div class="container-fluid assets-manager">
    <div class="row">
        <div class="col-md-3 border-end">
            <h5 class="mt-3">Clients</h5>
            <button class="btn btn-sm btn-primary mb-2" @onclick="NewClient">+ New</button>
            @if (clients is null)
            {
                <p><em>@L["common.loading", "Loading..."]</em></p>
            }
            else if (clients.Count == 0)
            {
                <p class="text-muted">@L["clients.emptyList", "No clients registered"]</p>
            }
            else
            {
                <ul class="list-group">
                    @foreach (var c in clients)
                    {
                        <li class="list-group-item list-group-item-action @(selected?.Id == c.Id ? "active" : "")"
                            style="cursor:pointer" @onclick="() => SelectClient(c)">
                            <div class="fw-bold">@c.LastName@(c.FirstName is not null ? $", {c.FirstName}" : "")</div>
                            <small>@c.Email @c.City</small>
                        </li>
                    }
                </ul>
            }
        </div>
        <div class="col-md-6 border-end">
            @if (editing)
            {
                <h5 class="mt-3">@(isNew ? "New Client" : "Edit Client")</h5>
                <div class="mb-3">
                    <h6 class="text-muted">Personal</h6>
                    <div class="row g-2">
                        <div class="col-6"><label>Last Name *</label><input class="form-control" @bind="form.LastName" /></div>
                        <div class="col-6"><label>First Name</label><input class="form-control" @bind="form.FirstName" /></div>
                        <div class="col-6"><label>Nickname</label><input class="form-control" @bind="form.Nickname" /></div>
                        <div class="col-6"><label>Gender</label><input class="form-control" @bind="form.Gender" /></div>
                        <div class="col-6"><label>Title</label><input class="form-control" @bind="form.Title" /></div>
                        <div class="col-6"><label>Language</label><input class="form-control" @bind="form.Language" /></div>
                    </div>
                </div>
                <div class="mb-3">
                    <h6 class="text-muted">Contact</h6>
                    <div class="row g-2">
                        <div class="col-6"><label>Phone</label><input class="form-control" @bind="form.Phone" /></div>
                        <div class="col-6"><label>Phone 2</label><input class="form-control" @bind="form.Phone2" /></div>
                        <div class="col-6"><label>Email</label><input class="form-control" @bind="form.Email" /></div>
                        <div class="col-6"><label>Email 2</label><input class="form-control" @bind="form.Email2" /></div>
                        <div class="col-6"><label>Fax</label><input class="form-control" @bind="form.Fax" /></div>
                    </div>
                </div>
                <div class="mb-3">
                    <h6 class="text-muted">Address</h6>
                    <div class="row g-2">
                        <div class="col-6"><label>Nation</label><input class="form-control" @bind="form.Nation" /></div>
                        <div class="col-6"><label>Region</label><input class="form-control" @bind="form.Region" /></div>
                        <div class="col-6"><label>City</label><input class="form-control" @bind="form.City" /></div>
                        <div class="col-6"><label>Street</label><input class="form-control" @bind="form.Street" /></div>
                        <div class="col-4"><label>Street No</label><input class="form-control" @bind="form.StreetNumber" /></div>
                        <div class="col-4"><label>Postal Code</label><input class="form-control" @bind="form.PostalCode" /></div>
                    </div>
                </div>
                <div class="mb-3">
                    <h6 class="text-muted">Document</h6>
                    <div class="row g-2">
                        <div class="col-6"><label>Doc Type</label><input class="form-control" @bind="form.DocumentType" /></div>
                        <div class="col-6"><label>Doc Number</label><input class="form-control" @bind="form.DocumentNumber" /></div>
                        <div class="col-6"><label>Doc Nation</label><input class="form-control" @bind="form.DocumentNation" /></div>
                    </div>
                </div>
                <div class="mb-3">
                    <h6 class="text-muted">Business</h6>
                    <div class="row g-2">
                        <div class="col-6"><label>Tax Code</label><input class="form-control" @bind="form.TaxCode" /></div>
                        <div class="col-6"><label>VAT Number</label><input class="form-control" @bind="form.VatNumber" /></div>
                    </div>
                </div>
                <div class="mb-3">
                    <h6 class="text-muted">Notes</h6>
                    <textarea class="form-control" rows="3" @bind="form.Notes"></textarea>
                </div>
                @if (!string.IsNullOrEmpty(errorMsg)) { <div class="alert alert-danger">@errorMsg</div> }
                <button class="btn btn-primary me-2" @onclick="Save">@L["common.save", "Save"]</button>
                <button class="btn btn-secondary" @onclick="Cancel">@L["common.cancel", "Cancel"]</button>
            }
        </div>
        <div class="col-md-3">
            @if (selected is not null && !editing)
            {
                <h5 class="mt-3">@L["common.details", "Details"]</h5>
                <dl>
                    <dt>Last Name</dt><dd>@selected.LastName</dd>
                    <dt>First Name</dt><dd>@selected.FirstName</dd>
                    <dt>Email</dt><dd>@selected.Email</dd>
                    <dt>Phone</dt><dd>@selected.Phone</dd>
                    <dt>City</dt><dd>@selected.City</dd>
                    <dt>Nation</dt><dd>@selected.Nation</dd>
                    <dt>Tax Code</dt><dd>@selected.TaxCode</dd>
                </dl>
                <button class="btn btn-sm btn-outline-primary me-1" @onclick="EditSelected">Edit</button>
                <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelected">@L["common.delete", "Delete"]</button>
            }
        </div>
    </div>
</div>

@code {
    private List<ClientDto>? clients;
    private ClientDto? selected;
    private bool editing;
    private bool isNew;
    private string errorMsg = "";
    private FormModel form = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAll();
    }

    private async Task LoadAll()
    {
        clients = await ClientApi.GetAllAsync();
    }

    private void NewClient()
    {
        form = new();
        isNew = true;
        editing = true;
        selected = null;
        errorMsg = "";
    }

    private void SelectClient(ClientDto c)
    {
        selected = c;
        editing = false;
        errorMsg = "";
    }

    private void EditSelected()
    {
        if (selected is null) return;
        form = new()
        {
            LastName = selected.LastName, FirstName = selected.FirstName, Nickname = selected.Nickname,
            Gender = selected.Gender, Title = selected.Title, Language = selected.Language,
            Phone = selected.Phone, Phone2 = selected.Phone2, Fax = selected.Fax,
            Email = selected.Email, Email2 = selected.Email2,
            Nation = selected.Nation, Region = selected.Region, City = selected.City,
            Street = selected.Street, StreetNumber = selected.StreetNumber, PostalCode = selected.PostalCode,
            DocumentType = selected.DocumentType, DocumentNumber = selected.DocumentNumber,
            DocumentNation = selected.DocumentNation,
            TaxCode = selected.TaxCode, VatNumber = selected.VatNumber, Notes = selected.Notes
        };
        isNew = false;
        editing = true;
        errorMsg = "";
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(form.LastName)) { errorMsg = "Last Name is required."; return; }
        var dto = new ClientDto(
            selected?.Id, form.LastName, form.FirstName, form.Nickname, form.Gender, form.Title, form.Language,
            null, null, null, null, form.DocumentNumber, null, form.DocumentType, null, null, form.DocumentNation,
            null, form.Nation, form.Region, form.City, form.Street, form.StreetNumber, form.PostalCode,
            form.Phone, form.Phone2, null, form.Fax, form.Email, form.Email2, null,
            form.TaxCode, form.VatNumber, form.Notes);
        try
        {
            if (isNew) await ClientApi.CreateAsync(dto);
            else await ClientApi.UpdateAsync(selected!.Id!, dto);
            editing = false;
            await LoadAll();
        }
        catch { errorMsg = "Save failed."; }
    }

    private void Cancel() { editing = false; errorMsg = ""; }

    private async Task DeleteSelected()
    {
        if (selected?.Id is null) return;
        try { await ClientApi.DeleteAsync(selected.Id); selected = null; await LoadAll(); }
        catch { errorMsg = "Delete failed."; }
    }

    private class FormModel
    {
        public string? LastName { get; set; }
        public string? FirstName { get; set; }
        public string? Nickname { get; set; }
        public string? Gender { get; set; }
        public string? Title { get; set; }
        public string? Language { get; set; }
        public string? Phone { get; set; }
        public string? Phone2 { get; set; }
        public string? Fax { get; set; }
        public string? Email { get; set; }
        public string? Email2 { get; set; }
        public string? Nation { get; set; }
        public string? Region { get; set; }
        public string? City { get; set; }
        public string? Street { get; set; }
        public string? StreetNumber { get; set; }
        public string? PostalCode { get; set; }
        public string? DocumentType { get; set; }
        public string? DocumentNumber { get; set; }
        public string? DocumentNation { get; set; }
        public string? TaxCode { get; set; }
        public string? VatNumber { get; set; }
        public string? Notes { get; set; }
    }
}


