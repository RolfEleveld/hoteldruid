@page "/setup"
@using System.Net
@using System.Net.Http.Json
@using HotelDruid.Client.Services
@using HotelDruid.Shared.Configuration
@inject HttpClient Http

@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Setup.PageTitle"]</PageTitle>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h1 class="h3 mb-3">@L["Setup.Header"]</h1>
                    <p class="text-muted">
                        @L["Setup.DescriptionPrefix"] <strong>/setup?configure=true</strong>@L["Setup.DescriptionSuffix"]
                    </p>

                    @if (!string.IsNullOrWhiteSpace(message))
                    {
                        <div class="alert alert-success">@message</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(error))
                    {
                        <div class="alert alert-danger">@error</div>
                    }

                    <div class="mb-3">
                        <label class="form-label">@L["Setup.SystemCurrency.Label"]</label>
                        <input class="form-control" @bind="model.DefaultCurrency" placeholder="@L["Setup.SystemCurrency.Placeholder"]" />
                        <div class="form-text">@L["Setup.SystemCurrency.Help"]</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">@L["Setup.DefaultYear.Label"]</label>
                        <input type="number" class="form-control" @bind="model.DefaultYear" min="2000" max="2100" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">@L["Setup.Fallback.Label"]</label>
                        <select class="form-select" @bind="pricingFallback">
                            @foreach (var optionValue in PricingFallbackOptions)
                            {
                                <option value="@optionValue">@GetPricingFallbackLabel(optionValue)</option>
                            }
                        </select>
                        <div class="form-text">@L["Setup.Fallback.Help"]</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">@L["Setup.Storage.Label"]</label>
                        <input class="form-control" value="@storageInfo?.DataRoot" readonly />
                        <div class="form-text">
                            @L["Setup.Storage.SourcePrefix"] <strong>@(storageInfo?.Source ?? L["Setup.Storage.Source.Unknown"])</strong>.
                            @L["Setup.Storage.HelpPrefix"]
                            <code>HOTELDRUID_DATAROOT</code> @L["Setup.Storage.HelpMiddle"] <code>DataRoot</code> @L["Setup.Storage.HelpSuffix"]
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" @onclick="SaveAsync">@L["Setup.Button.Save"]</button>
                        <a class="btn btn-outline-secondary" href="/">@L["Setup.Button.BackHome"]</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private sealed class StorageInfoResponse
    {
        public string DataRoot { get; set; } = string.Empty;
        public string Source { get; set; } = string.Empty;
        public string EnvironmentVariable { get; set; } = string.Empty;
        public string ConfigurationKey { get; set; } = string.Empty;
    }

    private SystemConfiguration model = new() { Id = "system", DefaultCurrency = "EUR", DefaultYear = DateTime.UtcNow.Year };
    private string pricingFallback = "LatestAvailableYear";
    private StorageInfoResponse? storageInfo;
    private static readonly IReadOnlyList<string> PricingFallbackOptions =
    [
        "LatestAvailableYear",
        "NoSuggestion"
    ];

    private string GetPricingFallbackLabel(string optionValue)
    {
        return optionValue switch
        {
            "LatestAvailableYear" => L["Setup.Fallback.Option.LatestAvailableYear"],
            "NoSuggestion" => L["Setup.Fallback.Option.NoSuggestion"],
            _ => optionValue
        };
    }

    private string? message;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            storageInfo = await Http.GetFromJsonAsync<StorageInfoResponse>("/api/system/storage");

            var existing = await Http.GetFromJsonAsync<SystemConfiguration>("/api/system/configuration");
            if (existing is not null)
            {
                model = existing;
                if (existing.Settings is not null && existing.Settings.TryGetValue("PriceFallback", out var value) && !string.IsNullOrWhiteSpace(value))
                {
                    pricingFallback = NormalizePricingFallback(value);
                }
            }
        }
        catch (HttpRequestException ex) when (ex.StatusCode == HttpStatusCode.NotFound)
        {
            // First-time setup without existing configuration.
        }
    }

    private async Task SaveAsync()
    {
        error = null;
        message = null;

        model.Id = "system";
        model.UpdatedUtc = DateTime.UtcNow;
        model.Settings ??= new Dictionary<string, string>();
        model.Settings["PriceFallback"] = NormalizePricingFallback(pricingFallback);

        var response = await Http.PutAsJsonAsync("/api/system/configuration", model);
        if (!response.IsSuccessStatusCode)
        {
            error = L["Setup.Error.SaveFailed"];
            return;
        }

        message = L["Setup.Message.SaveSuccess"];
    }

    private static string NormalizePricingFallback(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "LatestAvailableYear";
        }

        return PricingFallbackOptions.Contains(value, StringComparer.Ordinal) ? value : "LatestAvailableYear";
    }
}

