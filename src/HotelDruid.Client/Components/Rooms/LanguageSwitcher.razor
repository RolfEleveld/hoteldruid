@namespace HotelDruid.Client.Components.Rooms
@using HotelDruid.Client.Services
@inject IClientCultureService CultureService
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<div class="language-switcher" style="padding: 8px; background: #f5f5f5; border-radius: 5px; display: inline-block;">
    <label style="margin-right: 8px;">
        @L["language.switcher", "Language"]:
    </label>
    <select @onchange="@OnLanguageChanged" style="padding: 4px 8px; border-radius: 3px;">
        @foreach (var culture in CultureService.SupportedCultures)
        {
            <option value="@culture.Name" selected="@(CultureService.CurrentCulture.Name == culture.Name)">
                @GetLanguageLabel(culture.Name)
            </option>
        }
    </select>
</div>

@code {
    private Task OnLanguageChanged(ChangeEventArgs e)
    {
        var cultureName = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(cultureName))
        {
            return Task.CompletedTask;
        }

        return ApplyCultureAsync(cultureName);
    }

    private async Task ApplyCultureAsync(string cultureName)
    {
        await CultureService.SetCultureAsync(cultureName);
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
    }

    private static string GetLanguageLabel(string cultureName)
    {
        return cultureName switch
        {
            "en" or "en-US" => "English",
            "es" or "es-ES" => "Español",
            "it" or "it-IT" => "Italiano",
            _ => cultureName
        };
    }
}

