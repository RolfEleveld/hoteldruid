@namespace HotelDruid.Client.Components.Rooms
@using HotelDruid.Client.Services
@inject IRoomApiService RoomApiService
@inject IStringLocalizer<SharedResource> L

<div class="rpanels">
    <div class="rbox">
        <div class="rheader">@L["rooms.title", "Top Rooms"]</div>
        <div class="rcontent">
            <p>@L["rooms.description", "View and manage your hotel rooms"]</p>

            @if (RoomsLoading)
            {
                <p>@L["common.loading", "Loading..."]</p>
            }
            else if (!Rooms.Any())
            {
                <p>@L["rooms.emptyList", "No rooms available"]</p>
            }
            else
            {
                <table class="t1">
                    <thead>
                        <tr>
                            <th>@L["rooms.room", "Room"]</th>
                            <th>@L["rooms.capacity", "Capacity"]</th>
                            <th>@L["rooms.floor", "Floor"]</th>
                            <th>@L["rooms.house", "House"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var room in Rooms.Take(5))
                        {
                            <tr>
                                <td>@room.Name</td>
                                <td>@room.Capacity</td>
                                <td>@room.FloorNumber</td>
                                <td>@room.HouseNumber</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

<SettingsPanel @ref="SettingsPanel" 
    Title="@L["settings.title", "Settings & Management"]"
    Description="@L["settings.description", "Export and import room configurations"]">
</SettingsPanel>

@code {
    private List<RoomDto> Rooms = new();
    private bool RoomsLoading = false;
    private SettingsPanel? SettingsPanel;

    protected override async Task OnInitializedAsync()
    {
        await LoadRoomsAsync();
    }

    private async Task LoadRoomsAsync()
    {
        try
        {
            RoomsLoading = true;
            Rooms = await RoomApiService.GetRoomsAsync();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error loading rooms: {ex.Message}");
        }
        finally
        {
            RoomsLoading = false;
        }
    }

}


