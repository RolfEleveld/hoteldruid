@namespace HotelDruid.Client.Components.Warehouses
@using HotelDruid.Client.Services
@inject IWarehouseApiService WarehouseApi
@inject ILanguageService LanguageService
@implements IDisposable

<div class="rpanels">
    <div class="rbox">
        <div class="rheader">@LanguageService.GetText("warehouses.title","Top Warehouses")</div>
        <div class="rcontent">
            @if (Loading)
            {
                <p>@LanguageService.GetText("common.loading","Loading...")</p>
            }
            else if (!Items.Any())
            {
                <p>@LanguageService.GetText("warehouses.empty","No warehouses available")</p>
            }
            else
            {
                <table class="t1"><thead><tr><th>Name</th><th>Code</th></tr></thead><tbody>
                    @foreach (var w in Items.Take(5))
                    {
                        <tr><td>@w.Name</td><td>@w.Code</td></tr>
                    }
                </tbody></table>
            }
        </div>
    </div>
</div>

@code {
    private List<WarehouseDto> Items = new();
    private bool Loading = false;

    protected override async Task OnInitializedAsync()
    {
        LanguageService.LanguageChanged += OnLanguageChanged;
        await LanguageService.InitializeAsync();
        await LoadAsync();
    }

    private void OnLanguageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync()
    {
        try
        {
            Loading = true;
            Items = await WarehouseApi.GetWarehousesAsync();
        }
        catch { }
        finally { Loading = false; }
    }

    public void Dispose()
    {
        LanguageService.LanguageChanged -= OnLanguageChanged;
    }
}

